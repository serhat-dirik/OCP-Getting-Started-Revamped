<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <groupId>com.parasol</groupId>
  <artifactId>claims-db-mcp</artifactId>
  <version>1.0.0</version>
  <name>claims-db-mcp</name>
  <description>Parasol claims-db MCP server (Quarkus): exposes the CLM-1001..CLM-1030 claims dataset as MCP tools over HTTP-SSE. Consumed by parasol-agent in M23.</description>

  <properties>
    <maven.compiler.release>21</maven.compiler.release>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    <project.reporting.outputEncoding>UTF-8</project.reporting.outputEncoding>

    <!-- Quarkus current LTS: 3.33 (same BOM as every other Parasol service so they
         all move in lockstep). -->
    <quarkus.platform.group-id>io.quarkus.platform</quarkus.platform.group-id>
    <quarkus.platform.artifact-id>quarkus-bom</quarkus.platform.artifact-id>
    <quarkus.platform.version>3.33.2.1</quarkus.platform.version>

    <!-- Quarkus MCP Server extension (Quarkiverse). 1.13.1 is built against Quarkus
         3.33.2 (same LTS line as the platform BOM above). The artifact was renamed
         from quarkus-mcp-server-sse to -http in 1.8.0; the -http extension serves
         BOTH the Streamable-HTTP endpoint at /mcp AND the legacy SSE endpoint at
         /mcp/sse, which is the transport parasol-agent's langchain4j MCP client uses. -->
    <quarkus-mcp-server.version>1.13.1</quarkus-mcp-server.version>

    <compiler-plugin.version>3.13.0</compiler-plugin.version>
    <surefire-plugin.version>3.5.2</surefire-plugin.version>
    <skipITs>true</skipITs>
  </properties>

  <dependencyManagement>
    <dependencies>
      <dependency>
        <groupId>${quarkus.platform.group-id}</groupId>
        <artifactId>${quarkus.platform.artifact-id}</artifactId>
        <version>${quarkus.platform.version}</version>
        <type>pom</type>
        <scope>import</scope>
      </dependency>
    </dependencies>
  </dependencyManagement>

  <dependencies>
    <!-- MCP server over HTTP/SSE: turns @Tool methods into MCP tools served at
         /mcp (Streamable HTTP) and /mcp/sse (legacy SSE). This is the whole point
         of the service - "MCP tools are your APIs" (M23). -->
    <dependency>
      <groupId>io.quarkiverse.mcp</groupId>
      <artifactId>quarkus-mcp-server-http</artifactId>
      <version>${quarkus-mcp-server.version}</version>
    </dependency>
    <!-- Persistence: Panache active-record over Hibernate ORM. Reuses the exact
         parasol-claims Claim/ClaimEvent shape + import.sql seed so the tools serve
         the same deterministic CLM-1001..CLM-1030 dataset the whole workshop cites. -->
    <dependency>
      <groupId>io.quarkus</groupId>
      <artifactId>quarkus-hibernate-orm-panache</artifactId>
    </dependency>
    <!-- Embedded H2, seeded at boot from import.sql: the server is self-contained
         and deterministic (no external DB pod), which keeps M23 module-independent.
         The datasource is env-overridable to the shared claims PostgreSQL - see README. -->
    <dependency>
      <groupId>io.quarkus</groupId>
      <artifactId>quarkus-jdbc-h2</artifactId>
    </dependency>
    <!-- Health probes: /q/health/live and /q/health/ready (on by default - curriculum). -->
    <dependency>
      <groupId>io.quarkus</groupId>
      <artifactId>quarkus-smallrye-health</artifactId>
    </dependency>
    <!-- Prometheus metrics at /q/metrics (M11/M12 observability - the agent's tool
         calls land here as MCP request metrics). -->
    <dependency>
      <groupId>io.quarkus</groupId>
      <artifactId>quarkus-micrometer-registry-prometheus</artifactId>
    </dependency>
    <!-- Distributed tracing: OTLP spans so a tool call shows as its own span in the
         agent->claims-db trace (M12). Exporter is OFF by default (README) until a
         collector exists; turned on to Tempo via env. -->
    <dependency>
      <groupId>io.quarkus</groupId>
      <artifactId>quarkus-opentelemetry</artifactId>
    </dependency>

    <!-- Test-only: deterministic component tests over the tool logic (feeds CI "apps" job). -->
    <dependency>
      <groupId>io.quarkus</groupId>
      <artifactId>quarkus-junit5</artifactId>
      <scope>test</scope>
    </dependency>
    <dependency>
      <groupId>io.rest-assured</groupId>
      <artifactId>rest-assured</artifactId>
      <scope>test</scope>
    </dependency>
  </dependencies>

  <build>
    <plugins>
      <plugin>
        <groupId>${quarkus.platform.group-id}</groupId>
        <artifactId>quarkus-maven-plugin</artifactId>
        <version>${quarkus.platform.version}</version>
        <extensions>true</extensions>
        <executions>
          <execution>
            <goals>
              <goal>build</goal>
              <goal>generate-code</goal>
              <goal>generate-code-tests</goal>
            </goals>
          </execution>
        </executions>
      </plugin>
      <plugin>
        <artifactId>maven-compiler-plugin</artifactId>
        <version>${compiler-plugin.version}</version>
      </plugin>
      <plugin>
        <artifactId>maven-surefire-plugin</artifactId>
        <version>${surefire-plugin.version}</version>
        <configuration>
          <systemPropertyVariables>
            <java.util.logging.manager>org.jboss.logmanager.LogManager</java.util.logging.manager>
          </systemPropertyVariables>
        </configuration>
      </plugin>
    </plugins>
  </build>
</project>
