#!/usr/bin/env bash
#
# lab-serve — build the WORKSHOP flavor of the guide and serve it locally on :8080.
# Showroom-convention name (referenced by CLAUDE.md and docs/authoring-conventions.md).
# Override the port with PORT=9000 utilities/lab-serve.
set -euo pipefail

PORT="${PORT:-8080}"
repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
out_dir="${repo_root}/www/workshop"

# --- Build (Antora, via the repo's pinned devDependencies) --------------------
if ! command -v npx >/dev/null 2>&1; then
  echo "❌ npx (Node.js) not found — cannot build the Antora site."
  echo "   Fix: install Node.js >= 18 (nvm, or 'brew install node'), then run: npm install"
  exit 1
fi

if [ ! -d "${repo_root}/node_modules/@antora" ]; then
  echo "ℹ️  Antora not installed yet — running 'npm install' first…"
  ( cd "$repo_root" && npm install --no-audit --no-fund )
fi

echo "🔨 Building the workshop flavor…"
# Antora resolves the local content source from INSIDE content/ (content/site-workshop.yml
# uses url: .. -> repo root). Build from there so the relative path lands correctly.
( cd "${repo_root}/content" && npx antora --fetch site-workshop.yml )

if [ ! -f "${out_dir}/index.html" ]; then
  echo "❌ Build produced no site at ${out_dir} — check the Antora output above."
  exit 1
fi
echo "✅ Built: ${out_dir}"

# --- Serve --------------------------------------------------------------------
if command -v python3 >/dev/null 2>&1; then
  echo "🌐 Serving at http://localhost:${PORT}/ (Ctrl-C to stop)…"
  exec python3 -m http.server "$PORT" --directory "$out_dir"
fi

echo "⚠️  python3 not found — the site is built but not served."
echo "   Serve ${out_dir} with any static server, e.g.:"
echo "     podman run --rm -p ${PORT}:8080 -v ${out_dir}:/var/www/html/:z \\"
echo "       registry.access.redhat.com/ubi9/httpd-24:1-301"
echo "   or open ${out_dir}/index.html directly in a browser."
exit 1
