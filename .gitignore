# Secrets & environment — NEVER commit real endpoints/keys (03-DEV-WORKFLOW §8)
vars.yaml
*.kubeconfig
.env
.env.*
# Workshop bootstrap writes the generated user credentials here (never commit)
bootstrap/.credentials*

# Build outputs
slides/dist/
content/build/
build/
target/
node_modules/
.cache/
dist/
# Antora rendered sites (content/site-*.yml -> repo-root www/<flavor>)
www/
content/www/

# Local tooling noise
.DS_Store
*.log
.vale-cache/

# Claude Code local settings (project settings.json IS committed)
.claude/settings.local.json
.claude/launch.json

# kustomize helmCharts inflation pulls charts here at build time (Argo re-pulls on sync)
platform-portfolio/components/*/charts/
