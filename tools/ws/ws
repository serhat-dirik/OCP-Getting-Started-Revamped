#!/usr/bin/env bash
# ws — workshop state CLI: materialize, verify, and reset per-user module environments.
#
#   ws list                          modules with an entry state
#   ws prep   <module> [--yes]       ATTENDEE self-service: detect leftovers, offer wipe, prepare
#   ws start  <module> [--user U]    materialize the module's entry state for a user
#   ws verify <module> [--user U]    run the module's verification script
#   ws reset  <module> [--user U]    return the user's world to the module's entry state
#   ws solve  <module> [--user U]    materialize the END state (instructor only)
#   ws git-refresh                   re-sync the in-cluster Gitea mirrors from upstream
#   ws doctor                        environment sanity: login, argo, gitea, operators
#
# Entry states are Helm charts under gitops/entry-states/<module>/, materialized as
# Argo CD Applications (name: entry-<module>-<user>) sourced from the IN-CLUSTER Gitea
# mirror (git-localize) — the public repo stays the upstream source of truth.
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
ENTRY_DIR="${REPO_ROOT}/gitops/entry-states"
VERIFY_DIR="${REPO_ROOT}/tools/verify"
ARGO_NS="${WS_ARGO_NS:-openshift-gitops}"
ARGO_PROJECT="${WS_ARGO_PROJECT:-workshop-entries}"
GITEA_NS="${WS_GITEA_NS:-gitea}"
MIRROR_ORG="${WS_MIRROR_ORG:-parasol}"
MIRROR_REPO="${WS_MIRROR_REPO:-ocp-getting-started}"
SOURCE_REVISION="${WS_REVISION:-main}"

ok()   { echo "✅ $*"; }
err()  { echo "❌ $*" >&2; }
info() { echo "▶ $*"; }
die()  { err "$*"; exit 1; }

need_oc() {
  command -v oc >/dev/null || die "oc not found in PATH"
  oc whoami >/dev/null 2>&1 || die "not logged in — oc login first (KUBECONFIG=${KUBECONFIG:-~/.kube/config})"
}

# Source repo for entry-state Applications: prefer the local Gitea mirror (git-localize),
# fall back to upstream GitHub when the mirror isn't up (early bootstrap, laptop dev).
# Attendees can't read the gitea Route cross-namespace (rule 10), so derive the host from
# the cluster ingress domain — the same attendee-safe pattern the verify scripts use.
repo_url() {
  local host domain
  host="$(oc get route gitea -n "${GITEA_NS}" -o jsonpath='{.spec.host}' 2>/dev/null || true)"
  if [[ -z "$host" ]]; then
    domain="$(oc get ingresses.config cluster -o jsonpath='{.spec.domain}' 2>/dev/null || true)"
    [[ -n "$domain" ]] && host="gitea-${GITEA_NS}.${domain}"
  fi
  if [[ -n "$host" ]] && curl -ksf --max-time 5 "https://${host}/api/v1/version" >/dev/null 2>&1; then
    echo "https://${host}/${MIRROR_ORG}/${MIRROR_REPO}.git"
  else
    echo "https://github.com/serhat-dirik/OCP-Getting-Started-Revamped"
  fi
}

module_arg() {
  local m="${1:-}"
  [[ -n "$m" ]] || die "module required (e.g. m01) — see: ws list"
  m="$(echo "$m" | tr '[:upper:]' '[:lower:]')"
  [[ "$m" =~ ^m[0-9]{2}$ ]] || die "module must look like m01, got '$m'"
  echo "$m"
}

user_arg() {  # $1 = --user value or empty → default from oc whoami (attendee self-service)
  local u="${1:-}"
  if [[ -z "$u" ]]; then
    u="$(oc whoami 2>/dev/null || true)"
    # cluster admins get no implicit identity — they must say who they provision for
    [[ "$u" == system:admin || "$u" == *"kube:admin"* || "$u" == "admin" || -z "$u" ]] && u="user1"
  fi
  echo "$u"
}

app_name() { echo "entry-${1}-${2}"; }

argo_project() {  # workshop-entries once the workshop layer exists; default before that
  if oc get appproject "${ARGO_PROJECT}" -n "${ARGO_NS}" >/dev/null 2>&1; then
    echo "${ARGO_PROJECT}"
  else
    echo "⚠ AppProject ${ARGO_PROJECT} not found — using 'default' (apply the workshop layer for proper scoping)" >&2
    echo "default"
  fi
}

render_app() {  # module user [solve]  → Application manifest on stdout
  local module="$1" user="$2" solve="${3:-false}" url domain project
  url="$(repo_url)"
  domain="$(oc get ingresses.config cluster -o jsonpath='{.spec.domain}' 2>/dev/null || echo apps.example.com)"
  project="$(argo_project)"
  cat <<EOF
apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: $(app_name "$module" "$user")
  namespace: ${ARGO_NS}
  labels:
    workshop.redhat.com/module: "${module}"
    workshop.redhat.com/user: "${user}"
  finalizers:
    - resources-finalizer.argocd.argoproj.io
spec:
  project: ${project}
  source:
    repoURL: ${url}
    targetRevision: ${SOURCE_REVISION}
    path: gitops/entry-states/${module}
    helm:
      parameters:
        - name: user
          value: "${user}"
        - name: clusterDomain
          value: "${domain}"
        - name: solve
          value: "${solve}"
  destination:
    server: https://kubernetes.default.svc
  syncPolicy:
    automated:
      prune: true
      # selfHeal OFF by design: attendee edits to chart-owned workloads ARE the lab
      # (G3-M05: selfHeal reverted the attendee's 'oc set volume' within ~1s, so the
      # module's central exercise could never complete). Creation still auto-syncs;
      # 'ws reset' is the deliberate re-convergence path.
      selfHeal: false
    syncOptions:
      - CreateNamespace=false
    retry:
      limit: 10
      backoff: {duration: 10s, factor: 2, maxDuration: 2m}
EOF
}

meta_list() {  # file top-level-key → list items (naive block-scoped YAML list read)
  # Block-scoped on purpose: ws-meta.yaml now holds MULTIPLE lists (purgeNamespaces,
  # conflictsWith) — a bare 'grep -- -' would cross-contaminate them.
  awk -v k="$2:" '
    $0 ~ "^"k {f=1; next}
    f && /^[[:space:]]*-[[:space:]]/ {s=$0; sub(/^[[:space:]]*-[[:space:]]*/,"",s); gsub(/"/,"",s); print s; next}
    f && /^[^[:space:]#]/ {f=0}
  ' "$1"
}

meta_namespaces() {  # module user → ws-meta purgeNamespaces with ${USER} resolved
  local meta="${ENTRY_DIR}/${1}/ws-meta.yaml" item
  [[ -f "$meta" ]] || return 0
  meta_list "$meta" purgeNamespaces | while read -r item; do echo "${item//\$\{USER\}/${2}}"; done
}

meta_conflicts() {  # module → ws-meta conflictsWith module list
  local meta="${ENTRY_DIR}/${1}/ws-meta.yaml"
  [[ -f "$meta" ]] || return 0
  meta_list "$meta" conflictsWith
}

meta_wait() {  # module → per-module sync-wait seconds (ws-meta waitSeconds); empty = engine default.
  # Modules whose hooks do real work (m07 solve runs a ~9-min pipeline) declare a longer window.
  local meta="${ENTRY_DIR}/${1}/ws-meta.yaml"
  [[ -f "$meta" ]] || return 0
  awk '$1=="waitSeconds:"{print $2; exit}' "$meta"
}

meta_apps() {  # module user → "namespace project" if the module declares attendee-created Argo
  # Application CRs living OUTSIDE its purge namespaces (m09+: the student-gitops control plane —
  # ADR-0002 amendment 5: GitOps 1.21 refuses per-user source namespaces on a namespace-scoped
  # instance, so attendee apps live in the instance ns, isolated by Argo RBAC + AppProjects).
  # ws-meta keys: purgeAppsNamespace + purgeAppsProject (${USER} resolves).
  local meta="${ENTRY_DIR}/${1}/ws-meta.yaml" ns proj
  [[ -f "$meta" ]] || return 0
  ns="$(awk '$1=="purgeAppsNamespace:"{print $2; exit}' "$meta")"
  proj="$(awk '$1=="purgeAppsProject:"{print $2; exit}' "$meta")"
  [[ -n "$ns" && -n "$proj" ]] || return 0
  echo "${ns} ${proj//\$\{USER\}/${2}}"
}

purge_ns() {  # ns [keep-module] — delete user workloads/leftovers; preserve system objects
  # and ONLY the keep-module's entry marker. Preserving ALL ws-entry-* markers let stale
  # markers of long-gone modules survive every reset and false-green marker checks (G4-F9).
  local ns="$1" keep="${2:-}" kind name
  oc get ns "$ns" >/dev/null 2>&1 || return 0
  info "purging user workloads in ${ns}…"
  oc delete all,pvc --all -n "$ns" --wait=false >/dev/null 2>&1 || true
  # CRs 'oc delete all' misses: workspaces (M03+), Tekton runs (M07+), ImagePolicies (M08+) — extend
  # as modules add types. PipelineRuns cascade to their TaskRuns; deleting them also releases per-run
  # workspace PVCs. A leftover M08 ImagePolicy (block-unsigned) would otherwise block the next module's
  # image pulls in this namespace, so purge it too.
  oc delete devworkspaces.workspace.devfile.io --all -n "$ns" --wait=false >/dev/null 2>&1 || true
  oc delete pipelineruns.tekton.dev --all -n "$ns" --wait=false >/dev/null 2>&1 || true
  oc delete imagepolicies.config.openshift.io --all -n "$ns" --wait=false >/dev/null 2>&1 || true
  # Secrets/ConfigMaps the user created (e.g. template-instantiated DB creds) leak past
  # 'oc delete all' — purge them EXCEPT system objects and the current module's marker.
  for kind in secret configmap; do
    for name in $(oc get "$kind" -n "$ns" -o name 2>/dev/null); do
      case "$name" in
        */builder-dockercfg-*|*/default-dockercfg-*|*/deployer-dockercfg-*|*/builder-token-*|*/default-token-*|*/deployer-token-*|*/kube-root-ca.crt|*/openshift-service-ca.crt) ;;
        */ws-entry-${keep}) [[ -n "$keep" ]] || oc delete "$name" -n "$ns" --wait=false >/dev/null 2>&1 || true;;
        */ws-entry-*) oc delete "$name" -n "$ns" --wait=false >/dev/null 2>&1 || true;;
        *) oc delete "$name" -n "$ns" --wait=false >/dev/null 2>&1 || true;;
      esac
    done
  done
  ok "purge requested in ${ns}"
}

purge_apps() {  # module user [keep-module] — delete the user's Application CRs for this module.
  # These live in a control-plane namespace (ws-meta purgeAppsNamespace, e.g. student-gitops), NOT
  # in the module's purge namespaces, so purge_ns never sees them. Selected by .spec.project (the
  # per-user AppProject, e.g. proj-user7) — attendees create apps via the Argo UI and cannot be
  # relied on to label them. keep-module (M10 G1 engine flag #1): a module's OWN chart-materialized
  # apps carry workshop.redhat.com/module=<module> and share the same project as a conflicting
  # module's — on a bare re-start, gc must not purge the TARGET's own world (it would never
  # re-sync: the unchanged entry app is not recycled when nothing was evicted).
  local module="$1" user="$2" keep="${3:-}" pair ns proj name mod
  pair="$(meta_apps "$module" "$user")"
  [[ -n "$pair" ]] || return 0
  ns="${pair%% *}"; proj="${pair##* }"
  for name in $(oc get applications.argoproj.io -n "$ns" \
      -o jsonpath="{range .items[?(@.spec.project==\"${proj}\")]}{.metadata.name}{\"\n\"}{end}" 2>/dev/null); do
    if [[ -n "$keep" ]]; then
      mod="$(oc get application "$name" -n "$ns" -o jsonpath='{.metadata.labels.workshop\.redhat\.com/module}' 2>/dev/null || true)"
      [[ "$mod" == "$keep" ]] && continue
    fi
    info "deleting attendee Argo app ${ns}/${name} (project ${proj})…"
    oc delete application "$name" -n "$ns" --wait=true --timeout=120s >/dev/null 2>&1 \
      || oc patch application "$name" -n "$ns" --type merge -p '{"metadata":{"finalizers":null}}' >/dev/null 2>&1 || true
  done
}

gc_conflicts() {  # user module — evict conflicting modules' entry apps before materializing
  # Module independence (rule 2): entry charts that materialize the SAME named workloads
  # (declared in ws-meta conflictsWith) deadlock when their Argo apps coexist — both go
  # OutOfSync on SharedResourceWarning and the attendee gets a silently wrong world while
  # the marker check stays green (G3-M04, m03+m04 on user3). Starting a module therefore
  # evicts the conflicting app and purges this module's namespaces (= reset semantics).
  # Disjoint modules (m01 parasol-web, m06 {user}-batch) still coexist untouched.
  local user="$1" module="$2" evicted=0 c app ns
  for c in $(meta_conflicts "$module"); do
    app="$(app_name "$c" "$user")"
    if oc get application "$app" -n "$ARGO_NS" >/dev/null 2>&1; then
      info "evicting conflicting entry app ${app} (shares workloads with ${module})…"
      oc delete application "$app" -n "$ARGO_NS" --wait=true --timeout=180s || true
      evicted=1
    else
      # The conflicting module's app may be long gone while its ORPHANED leftovers still
      # squat in our namespaces (bare 'oc delete application' skips the purge — G4-F3:
      # start over such leftovers produced a wrong entry state behind partly-green checks).
      # A surviving marker is the tell — trigger the purge path even with no app to evict.
      for ns in $(meta_namespaces "$module" "$user"); do
        if oc get cm "ws-entry-${c}" -n "$ns" >/dev/null 2>&1; then
          info "found orphaned ${c} leftovers in ${ns} (marker, no app) — reclaiming…"
          evicted=1; break
        fi
      done
    fi
    # The conflicting module's attendee-created Argo apps (ws-meta purgeApps*) live in a
    # control-plane ns and would keep selfHeal-ing its world back — purge them regardless
    # of whether the entry app itself was still present. Keep the TARGET module's own
    # chart-labeled apps: on a bare re-start nothing recycles the entry app, so purging
    # its world would wipe it permanently (M10 G1 flag #1).
    purge_apps "$c" "$user" "$module"
  done
  if [[ "$evicted" == 1 ]]; then
    for ns in $(meta_namespaces "$module" "$user"); do purge_ns "$ns" "$module"; done
    # The purge also removed THIS module's chart-owned resources if its app pre-existed.
    # With selfHeal off, re-applying an UNCHANGED app never re-syncs them — recycle the
    # app so the fresh apply is a creation, which always auto-syncs.
    app="$(app_name "$module" "$user")"
    oc delete application "$app" -n "$ARGO_NS" --wait=true --timeout=180s >/dev/null 2>&1 || true
  fi
}

wait_healthy() {  # appname [timeout_s]
  local app="$1" timeout="${2:-300}" t=0 health sync phase empty_ok=0
  info "waiting for ${app} to sync (up to ${timeout}s)…"
  while (( t < timeout )); do
    health="$(oc get application "$app" -n "$ARGO_NS" -o jsonpath='{.status.health.status}' 2>/dev/null || true)"
    sync="$(oc get application "$app" -n "$ARGO_NS" -o jsonpath='{.status.sync.status}' 2>/dev/null || true)"
    # Hooks keep the sync OPERATION Running after the app already reads Synced/Healthy — and a
    # solve hook that does real work (m07: runs the whole pipeline) is exactly the point. Ready
    # means the operation finished too, or "demo-ready" prints while the namespace is still empty.
    phase="$(oc get application "$app" -n "$ARGO_NS" -o jsonpath='{.status.operationState.phase}' 2>/dev/null || true)"
    if [[ "$health" == "Healthy" && "$sync" == "Synced" ]]; then
      if [[ "$phase" == "Succeeded" ]]; then
        ok "entry state ready (Synced/Healthy)"
        return 0
      fi
      # Empty phase can be a transient window BETWEEN hook retries (M10 G1 flag #3: a failing
      # PostSync hook briefly reads Synced/Healthy/no-op) — accept it only after it HOLDS.
      if [[ -z "$phase" ]]; then
        empty_ok=$((empty_ok+1))
        if (( empty_ok >= 3 )); then
          ok "entry state ready (Synced/Healthy)"
          return 0
        fi
      else
        empty_ok=0
      fi
    else
      empty_ok=0
    fi
    sleep 5; t=$((t+5))
  done
  err "entry state not ready after ${timeout}s (health=${health:-?} sync=${sync:-?} op=${phase:-?})"
  echo "   inspect: oc describe application ${app} -n ${ARGO_NS}"
  return 1
}

cmd_list() {
  echo "Modules with entry states:"
  local found=0
  for d in "${ENTRY_DIR}"/m*/; do
    [[ -d "$d" ]] || continue
    found=1
    local m desc
    m="$(basename "$d")"
    desc="$(grep -m1 '^description:' "${d}Chart.yaml" 2>/dev/null | sed 's/description:[[:space:]]*//' || true)"
    printf "  %-6s %s\n" "$m" "${desc:-—}"
  done
  [[ "$found" == 1 ]] || echo "  (none yet)"
}

cmd_start() {
  local module user="$1" ; module="$2"
  need_oc
  [[ -d "${ENTRY_DIR}/${module}" ]] || die "no entry state for ${module} (${ENTRY_DIR}/${module})"
  # --all-users: instructor convenience — entry states are provisioned by instructors/automation
  # (attendees lack Application-create rights on the platform Argo instance by design, ADR-0002).
  if [[ "$user" == "--all-users" || "$user" == "all" ]]; then
    local n
    n="$(oc get group workshop-attendees -o jsonpath='{.users[*]}' 2>/dev/null | wc -w | xargs)"
    [[ "$n" -gt 0 ]] || die "cannot enumerate workshop-attendees group"
    info "materializing ${module} for all ${n} attendees…"
    for u in $(oc get group workshop-attendees -o jsonpath='{.users[*]}'); do
      gc_conflicts "$u" "$module"
      render_app "$module" "$u" | oc apply -f - >/dev/null
      echo "  ✓ ${u}"
    done
    ok "entry apps applied for ${n} users — sync continues in-cluster (watch: oc get applications -n ${ARGO_NS})"
    return 0
  fi
  gc_conflicts "$user" "$module"
  info "materializing ${module} entry state for ${user}…"
  render_app "$module" "$user" | oc apply -f -
  wait_healthy "$(app_name "$module" "$user")" "$(meta_wait "$module")"
  echo
  ok "${user} can start ${module}."
}

cmd_prep() {  # ATTENDEE self-service (Serhat directive 2026-07-10): attendees forget to wipe the
  # previous module before starting the next, and prep must never depend on an instructor.
  # Detect what's in the user's world, say it plainly, ask consent, then run the proven
  # purge-first reset path. Requires the per-user Argo RBAC from the workshop layer
  # (gitops/workshop-config/templates/per-user-argo-rbac.yaml).
  local module user="$1"; module="$2"; shift 2 || true
  local yes="false"
  [[ "${1:-}" == "--yes" || "${1:-}" == "-y" ]] && yes="true"
  need_oc
  [[ -d "${ENTRY_DIR}/${module}" ]] || die "no entry state for ${module} (${ENTRY_DIR}/${module})"
  local app; app="$(app_name "$module" "$user")"

  info "checking your ${module} environment (${user})…"
  local findings=() ns c capp
  # 1. Leftovers from OTHER modules in the namespaces this module owns/purges.
  for ns in $(meta_namespaces "$module" "$user"); do
    oc get ns "$ns" >/dev/null 2>&1 || continue
    local foreign
    foreign="$(oc get cm -n "$ns" -o name 2>/dev/null | sed -n 's|configmap/ws-entry-||p' | grep -v "^${module}\$" || true)"
    [[ -n "$foreign" ]] && findings+=("${ns} still holds state from module(s): $(echo "$foreign" | tr '\n' ' ')")
    local workloads
    workloads="$(oc get deploy,statefulsets,jobs,cronjobs -n "$ns" --no-headers 2>/dev/null | wc -l | tr -d ' ')"
    [[ "$workloads" -gt 0 && -z "$(oc get cm "ws-entry-${module}" -n "$ns" -o name 2>/dev/null)" ]] \
      && findings+=("${ns} has ${workloads} workload(s) but no ${module} marker")
  done
  # 2. Conflicting modules' entry apps still live (would deadlock this module's world).
  for c in $(meta_conflicts "$module"); do
    capp="$(app_name "$c" "$user")"
    oc get application "$capp" -n "$ARGO_NS" >/dev/null 2>&1 && findings+=("conflicting module ${c} is still provisioned (${capp})")
  done
  # 3. The module's own state: app + marker + entry verify.
  local have_app="false"
  oc get application "$app" -n "$ARGO_NS" >/dev/null 2>&1 && have_app="true"
  if [[ "$have_app" == "true" && ${#findings[@]} -eq 0 ]]; then
    local script="${VERIFY_DIR}/${module}.sh"
    if [[ -x "$script" ]] && "$script" --user "$user" --entry-only >/dev/null 2>&1; then
      ok "your ${module} environment is already prepared — nothing to do."
      echo "   (want a factory-fresh copy anyway? re-run with: ws prep ${module} --yes)"
      [[ "$yes" != "true" ]] && return 0
      findings+=("re-prep requested with --yes")
    else
      findings+=("${module} is provisioned but its entry checks are not passing")
    fi
  fi
  [[ "$have_app" == "false" ]] && findings+=("${module} is not provisioned for ${user} yet")

  echo
  echo "Found:"
  local f; for f in "${findings[@]}"; do echo "  • $f"; done
  echo
  echo "Preparing ${module} will WIPE the leftovers above (your namespaces are purged and"
  echo "re-materialized; anything you built in them is deleted) and set up a clean ${module} world."
  if [[ "$yes" != "true" ]]; then
    if [[ -t 0 ]]; then
      local reply
      read -r -p "Wipe and prepare ${module} now? [y/N] " reply
      [[ "$reply" =~ ^[Yy]([Ee][Ss])?$ ]] || { info "nothing changed. Re-run when ready (or use --yes)."; return 0; }
    else
      die "not a terminal and no --yes given — re-run: ws prep ${module} --yes"
    fi
  fi

  cmd_reset "$user" "$module"
  echo
  local script="${VERIFY_DIR}/${module}.sh"
  if [[ -x "$script" ]]; then
    if "$script" --user "$user" --entry-only; then
      ok "${module} is ready — start the lab."
    else
      info "setup hooks may still be settling (seeding data takes up to ~1 min) — re-check with: ws verify ${module}"
    fi
  fi
}

cmd_verify() {
  local module user="$1"; module="$2"; shift 2 || true
  need_oc
  local script="${VERIFY_DIR}/${module}.sh"
  [[ -x "$script" ]] || die "no verify script for ${module} (${script})"
  "$script" --user "$user" "$@"
}

cmd_reset() {
  local module user="$1"; module="$2"
  need_oc
  local app; app="$(app_name "$module" "$user")"
  info "resetting ${module} for ${user} (purge + delete + re-materialize)…"

  # Purge FIRST — this ordering is load-bearing (G3-M06 SEV1). Attendee-created workloads (Jobs/
  # pods the entry app does NOT own) can pin a chart-owned PVC through kubernetes.io/pvc-protection.
  # If we delete the Application first, its resources-finalizer blocks indefinitely trying to prune
  # that PVC while the pods holding it are never removed (they aren't app-owned), and the purge that
  # WOULD remove them never runs. Purging first deletes those pods (Completed pods drain in ~1s),
  # releases the PVC, and empties the namespace; with selfHeal:false the still-present app never
  # re-creates what we delete (it only marks OutOfSync). This also hardens m05's StatefulSet reset,
  # where volumeClaimTemplate PVCs are pinned the same way.
  # Attendee-created Argo apps FIRST (ws-meta purgeApps*): they live outside the purge namespaces,
  # and a selfHeal app re-deploys its workloads DURING the namespace purge and orphans them if the
  # purge runs first (reproduced live, M09 G1 — gc_conflicts always had this order; reset now matches).
  purge_apps "$module" "$user"
  local ns
  for ns in $(meta_namespaces "$module" "$user"); do purge_ns "$ns" "$module"; done

  # Now remove the GitOps wrapper. With the namespace already emptied the finalizer has little or
  # nothing left to prune and completes fast; if it still lingers, strip the finalizer rather than
  # fail the reset — the manual purge already did the pruning the finalizer exists to do.
  if oc get application "$app" -n "$ARGO_NS" >/dev/null 2>&1; then
    if ! oc delete application "$app" -n "$ARGO_NS" --wait=true --timeout=120s; then
      info "finalizer still settling — namespace already purged, removing it…"
      oc patch application "$app" -n "$ARGO_NS" --type=json \
        -p '[{"op":"remove","path":"/metadata/finalizers"}]' >/dev/null 2>&1 || true
      local t=0
      while oc get application "$app" -n "$ARGO_NS" >/dev/null 2>&1; do
        (( t >= 60 )) && die "entry app ${app} stuck deleting — inspect: oc get application ${app} -n ${ARGO_NS} -o yaml (finalizers)"
        sleep 3; t=$((t+3))
      done
    fi
    ok "chart-owned state pruned"
  else
    info "no existing entry app — clean start"
  fi
  cmd_start "$user" "$module"
}

cmd_solve() {  # instructor: materialize the module END state (entry chart with solve=true)
  local module user="$1"; module="$2"
  need_oc
  [[ -d "${ENTRY_DIR}/${module}" ]] || die "no entry state for ${module}"
  grep -q '^solve:' "${ENTRY_DIR}/${module}/values.yaml" 2>/dev/null \
    || die "${module}'s chart defines no solve state (values.yaml lacks 'solve:')"
  gc_conflicts "$user" "$module"
  info "materializing ${module} END state for ${user} (instructor solve)…"
  render_app "$module" "$user" "true" | oc apply -f -
  wait_healthy "$(app_name "$module" "$user")" "$(meta_wait "$module")"
  echo
  ok "${module} solved for ${user} — demo-ready."
}

cmd_git_refresh() {
  need_oc
  info "re-running the git-localize mirror sync…"
  # Re-sync of the mirror app re-fires its Sync-hook Job (BeforeHookCreation).
  if command -v argocd >/dev/null 2>&1 && argocd account get-user-info >/dev/null 2>&1; then
    argocd app sync pp-git-mirror --async >/dev/null && ok "mirror sync triggered (argocd)"
  else
    # No argocd CLI session — nudge via annotation refresh + let selfHeal re-run the hook.
    oc annotate application pp-git-mirror -n "$ARGO_NS" \
      argocd.argoproj.io/refresh=hard --overwrite >/dev/null
    ok "mirror refresh requested (hard refresh annotation)"
  fi
  echo "   watch: oc get jobs -n ${GITEA_NS} -w"
}

cmd_doctor() {
  need_oc
  echo "ws doctor — environment sanity"
  local fail=0
  printf "  %-28s" "cluster login"
  if oc whoami >/dev/null 2>&1; then ok "$(oc whoami) @ $(oc whoami --show-server)"; else err "not logged in"; fail=1; fi
  printf "  %-28s" "gitops operator"
  local csv
  csv="$(oc get csv -n openshift-gitops-operator -o jsonpath='{.items[?(@.spec.displayName=="Red Hat OpenShift GitOps")].status.phase}' 2>/dev/null || true)"
  if [[ "$csv" == *Succeeded* ]]; then ok "installed"; else err "not ready (${csv:-missing})"; fail=1; fi
  printf "  %-28s" "argo applications"
  local bad
  bad="$(oc get applications -n "$ARGO_NS" -o jsonpath='{range .items[*]}{.metadata.name}={.status.health.status} {end}' 2>/dev/null | tr ' ' '\n' | grep -v '=Healthy' | grep -v '^$' || true)"
  if [[ -z "$bad" ]]; then ok "all Healthy"; else err "unhealthy: $(echo "$bad" | tr '\n' ' ')"; fail=1; fi
  printf "  %-28s" "gitea"
  local host
  host="$(oc get route gitea -n "$GITEA_NS" -o jsonpath='{.spec.host}' 2>/dev/null || true)"
  if [[ -n "$host" ]] && curl -ksf "https://${host}/api/v1/version" >/dev/null 2>&1; then ok "https://${host}"; else err "unreachable"; fail=1; fi
  printf "  %-28s" "mirror (${MIRROR_ORG}/${MIRROR_REPO})"
  if [[ -n "$host" ]] && curl -ksf "https://${host}/api/v1/repos/${MIRROR_ORG}/${MIRROR_REPO}" >/dev/null 2>&1; then ok "mirrored"; else err "missing — run: ws git-refresh"; fail=1; fi
  printf "  %-28s" "workshop layer"
  local wsh
  wsh="$(oc get application workshop-config -n "$ARGO_NS" -o jsonpath='{.status.health.status}' 2>/dev/null || true)"
  if [[ "$wsh" == "Healthy" ]]; then ok "workshop-config Healthy"; else err "workshop-config ${wsh:-absent} — run bootstrap/install.sh"; fail=1; fi
  printf "  %-28s" "workshop IdP"
  if oc get oauth cluster -o jsonpath='{.spec.identityProviders[*].name}' 2>/dev/null | grep -qw workshop-users; then ok "workshop-users present"; else err "IdP missing — bootstrap adds it"; fail=1; fi
  printf "  %-28s" "user namespaces"
  if oc get ns user1-dev >/dev/null 2>&1; then ok "user1-dev exists"; else err "missing — workshop-config not synced"; fail=1; fi
  echo
  if (( fail == 0 )); then ok "environment looks good"; else err "issues found — fix hints above"; exit 1; fi
}

main() {
  local cmd="${1:-}"; shift || true
  local user="" module="" extra=()
  # collect --user anywhere; first bare arg = module
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --user) user="$2"; shift 2;;
      --all-users) user="--all-users"; shift;;
      -*) extra+=("$1"); shift;;
      *) [[ -z "$module" ]] && module="$1" || extra+=("$1"); shift;;
    esac
  done
  case "$cmd" in
    list)        cmd_list;;
    prep)        cmd_prep "$(user_arg "$user")" "$(module_arg "$module")" ${extra[@]:+"${extra[@]}"};;
    start)       cmd_start "$(user_arg "$user")" "$(module_arg "$module")";;
    verify)      cmd_verify "$(user_arg "$user")" "$(module_arg "$module")" ${extra[@]:+"${extra[@]}"};;
    reset)       cmd_reset "$(user_arg "$user")" "$(module_arg "$module")";;
    solve)       cmd_solve "$(user_arg "$user")" "$(module_arg "$module")";;
    git-refresh) cmd_git_refresh;;
    doctor)      cmd_doctor;;
    ""|help|-h|--help) grep '^#' "$0" | sed 's/^# \{0,1\}//' | sed -n '2,12p';;
    *) die "unknown command '$cmd' — try: ws help";;
  esac
}
main "$@"
