#!/usr/bin/env bash
# ws — workshop state CLI: materialize, verify, and reset per-user module environments.
#
#   ws list                          modules with an entry state
#   ws prep   <module> [--yes]       ATTENDEE self-service: detect leftovers, offer wipe, prepare
#   ws start  <module> [--user U]    materialize the module's entry state for a user
#   ws verify <module> [--user U]    run the module's verification script
#   ws smoke  <module> [userN]       G1 attendee-cockpit gate: run the attendee path IN the live cockpit
#   ws reset  <module> [--user U]    return the user's world to the module's entry state
#   ws solve  <module> [--user U]    materialize the END state (instructor only)
#   ws git-refresh [--restart-terminals]   re-sync mirror+Argo; opt-in: restart cockpit terminal pods
#   ws doctor                        environment sanity: login, argo, gitea, operators
#
# Entry states are Helm charts under gitops/entry-states/<module>/, materialized as
# Argo CD Applications (name: entry-<module>-<user>) sourced from the IN-CLUSTER Gitea
# mirror (git-localize) — the public repo stays the upstream source of truth.
#
# Publishing content to a LIVE session (commit + push) has two freshness paths:
#   • the ws CLI SELF-HEALS: when a module's entry state / verify script is absent from this
#     terminal's pod-local clone, ws pulls the clone up to the mirror and retries once — so a
#     just-published module becomes runnable on the next `ws` command with NO pod restart.
#   • rendered lab PAGES build at pod-init, so they refresh only on a pod restart:
#     ws git-refresh --restart-terminals [--user U | --all] [--exclude U]  (reserved sessions,
#     WS_RESERVED_USERS default 'user5', are never cycled by --all — name one with --user to override).
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
ENTRY_DIR="${REPO_ROOT}/gitops/entry-states"
VERIFY_DIR="${REPO_ROOT}/tools/verify"
ARGO_NS="${WS_ARGO_NS:-openshift-gitops}"
ARGO_PROJECT="${WS_ARGO_PROJECT:-workshop-entries}"
GITEA_NS="${WS_GITEA_NS:-gitea}"
STUDENT_ARGO_NS="${WS_STUDENT_ARGO_NS:-student-gitops}"
MIRROR_ORG="${WS_MIRROR_ORG:-parasol}"
MIRROR_REPO="${WS_MIRROR_REPO:-ocp-getting-started}"
SOURCE_REVISION="${WS_REVISION:-main}"
SHOWROOM_NS="${WS_SHOWROOM_NS:-showroom}"

# `ws smoke` targets the LIVE cockpit pod (showroom-<user>) and its ttyd shell container. SMOKE_POD/
# SMOKE_NS are resolved per-run in cmd_smoke; declared here so the pod_i/pod_x exec helpers (dynamic
# scope) reference an assigned global (shellcheck-clean) rather than an unset one.
SMOKE_NS=""
SMOKE_POD=""
SMOKE_CONTAINER="terminal"

ok()   { echo "✅ $*"; }
err()  { echo "❌ $*" >&2; }
info() { echo "▶ $*"; }
die()  { err "$*"; exit 1; }

need_oc() {
  command -v oc >/dev/null || die "oc not found in PATH"
  oc whoami >/dev/null 2>&1 || die "not logged in — oc login first (KUBECONFIG=${KUBECONFIG:-~/.kube/config})"
}

# Source repo for entry-state Applications: prefer the local Gitea mirror (git-localize),
# fall back to upstream GitHub when the mirror isn't up (early bootstrap, laptop dev).
# Attendees can't read the gitea Route cross-namespace (rule 10), so derive the host from
# the cluster ingress domain — the same attendee-safe pattern the verify scripts use.
repo_url() {
  local host domain
  host="$(oc get route gitea -n "${GITEA_NS}" -o jsonpath='{.spec.host}' 2>/dev/null || true)"
  if [[ -z "$host" ]]; then
    domain="$(oc get ingresses.config cluster -o jsonpath='{.spec.domain}' 2>/dev/null || true)"
    [[ -n "$domain" ]] && host="gitea-${GITEA_NS}.${domain}"
  fi
  if [[ -n "$host" ]] && curl -ksf --max-time 5 "https://${host}/api/v1/version" >/dev/null 2>&1; then
    echo "https://${host}/${MIRROR_ORG}/${MIRROR_REPO}.git"
  else
    echo "https://github.com/serhat-dirik/OCP-Getting-Started-Revamped"
  fi
}

# ── self-heal: keep this terminal's clone current without a pod restart ───────────────────────
# The attendee terminal runs `ws` from a pod-local clone (~/ocp-getting-started == REPO_ROOT) that
# the showroom terminal-prep initContainer refreshes ONLY at pod start. A module published AFTER the
# pod booted is therefore invisible here — its entry state / verify script is absent and every
# resolver dies "no entry state" (SEV1, M13 G3: `ws prep m13` failed in a live cockpit while the
# module had already reached the cluster via Argo). On a miss we pull the clone up to its origin —
# the in-cluster Gitea mirror that `ws git-refresh` advances — and retry the resolution ONCE.
_ws_healed=0
heal_clone() {  # → 0 if the clone was refreshed; 1 if we must fall back to the on-disk content
  [[ "$_ws_healed" == 0 ]] || return 1                                # at most one fetch per run (retry ONCE)
  _ws_healed=1
  git -C "$REPO_ROOT" rev-parse --git-dir >/dev/null 2>&1 || return 1 # not a git clone — nothing to heal
  local origin
  origin="$(git -C "$REPO_ROOT" remote get-url origin 2>/dev/null || true)"
  # Guard to a MIRROR clone: a laptop dev tree's origin is GitHub and must never be `reset --hard`
  # out from under uncommitted work; only the cockpit clone (origin = ${MIRROR_ORG}/${MIRROR_REPO})
  # is disposable and safe to hard-reset. Also keeps `ws` on a laptop from touching the working tree.
  [[ "$origin" == *"${MIRROR_ORG}/${MIRROR_REPO}"* ]] || return 1
  info "content may be missing from this terminal's clone — refreshing from the mirror…"
  if git -C "$REPO_ROOT" fetch --depth 1 origin "$SOURCE_REVISION" >/dev/null 2>&1 \
     && git -C "$REPO_ROOT" reset --hard "origin/${SOURCE_REVISION}" >/dev/null 2>&1; then
    ok "clone refreshed to $(git -C "$REPO_ROOT" rev-parse --short HEAD 2>/dev/null || echo '?')"
    return 0
  fi
  # Network-tolerant: a transient mirror outage must degrade to the normal error, never hard-crash.
  err "could not refresh the clone from the mirror (transient? try: ws git-refresh) — using on-disk content"
  return 1
}

require_entry_dir() {  # module → guarantee its entry-state dir exists, self-healing once on a miss
  local module="$1"
  [[ -d "${ENTRY_DIR}/${module}" ]] && return 0
  heal_clone && [[ -d "${ENTRY_DIR}/${module}" ]] && return 0
  die "no entry state for ${module} (${ENTRY_DIR}/${module})"
}

require_verify_script() {  # module → guarantee its verify script exists, self-healing once on a miss
  local script="${VERIFY_DIR}/${1}.sh"
  [[ -x "$script" ]] && return 0
  heal_clone && [[ -x "$script" ]] && return 0
  die "no verify script for ${1} (${script})"
}

mirror_head() {  # → the SHA the Gitea mirror serves on ${SOURCE_REVISION}, or empty if unreachable
  local host origin
  # Derive the mirror host attendee-safely from the clone's own origin (attendees can't read the
  # gitea Route cross-namespace, rule 10); fall back to the Route for an operator/admin context.
  origin="$(git -C "$REPO_ROOT" remote get-url origin 2>/dev/null || true)"
  if [[ "$origin" == *"${MIRROR_ORG}/${MIRROR_REPO}"* ]]; then
    host="${origin#https://}"; host="${host%%/*}"
  else
    host="$(oc get route gitea -n "${GITEA_NS}" -o jsonpath='{.spec.host}' 2>/dev/null || true)"
  fi
  [[ -n "$host" ]] || return 1
  curl -ksf --max-time 5 "https://${host}/api/v1/repos/${MIRROR_ORG}/${MIRROR_REPO}/branches/${SOURCE_REVISION}" 2>/dev/null \
    | sed -n 's/.*"id":"\([a-f0-9]*\)".*/\1/p' | head -1
}

heal_if_behind() {  # `ws list` freshness: refresh the clone ONLY when it is behind the mirror (the
  # "miss" for a command with no module arg), so a just-published module lists without a pod restart.
  # The compare is one lightweight API GET; the git fetch runs only when actually behind.
  git -C "$REPO_ROOT" rev-parse --git-dir >/dev/null 2>&1 || return 0
  local origin want have
  origin="$(git -C "$REPO_ROOT" remote get-url origin 2>/dev/null || true)"
  [[ "$origin" == *"${MIRROR_ORG}/${MIRROR_REPO}"* ]] || return 0     # not a mirror clone → nothing to heal
  want="$(mirror_head || true)"
  [[ -n "$want" ]] || return 0                                        # mirror unreachable → list on-disk
  have="$(git -C "$REPO_ROOT" rev-parse HEAD 2>/dev/null || true)"
  [[ "$want" == "$have" ]] && return 0                                # already current → no fetch
  heal_clone || true
}

module_arg() {
  local m="${1:-}"
  [[ -n "$m" ]] || die "module required (e.g. m01) — see: ws list"
  m="$(echo "$m" | tr '[:upper:]' '[:lower:]')"
  [[ "$m" =~ ^m[0-9]{2}$ ]] || die "module must look like m01, got '$m'"
  echo "$m"
}

user_arg() {  # $1 = --user value or empty → default from oc whoami (attendee self-service)
  local u="${1:-}"
  if [[ -z "$u" ]]; then
    u="$(oc whoami 2>/dev/null || true)"
    # cluster admins get no implicit identity — they must say who they provision for
    [[ "$u" == system:admin || "$u" == *"kube:admin"* || "$u" == "admin" || -z "$u" ]] && u="user1"
  fi
  echo "$u"
}

app_name() { echo "entry-${1}-${2}"; }

argo_project() {  # workshop-entries once the workshop layer exists; default before that
  if oc get appproject "${ARGO_PROJECT}" -n "${ARGO_NS}" >/dev/null 2>&1; then
    echo "${ARGO_PROJECT}"
  else
    echo "⚠ AppProject ${ARGO_PROJECT} not found — using 'default' (apply the workshop layer for proper scoping)" >&2
    echo "default"
  fi
}

render_app() {  # module user [solve]  → Application manifest on stdout
  local module="$1" user="$2" solve="${3:-false}" url domain project
  url="$(repo_url)"
  domain="$(oc get ingresses.config cluster -o jsonpath='{.spec.domain}' 2>/dev/null || echo apps.example.com)"
  project="$(argo_project)"
  cat <<EOF
apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: $(app_name "$module" "$user")
  namespace: ${ARGO_NS}
  labels:
    workshop.redhat.com/module: "${module}"
    workshop.redhat.com/user: "${user}"
  finalizers:
    - resources-finalizer.argocd.argoproj.io
spec:
  project: ${project}
  source:
    repoURL: ${url}
    targetRevision: ${SOURCE_REVISION}
    path: gitops/entry-states/${module}
    helm:
      parameters:
        - name: user
          value: "${user}"
        - name: clusterDomain
          value: "${domain}"
        - name: solve
          value: "${solve}"
  destination:
    server: https://kubernetes.default.svc
  syncPolicy:
    automated:
      prune: true
      # selfHeal OFF by design: attendee edits to chart-owned workloads ARE the lab
      # (G3-M05: selfHeal reverted the attendee's 'oc set volume' within ~1s, so the
      # module's central exercise could never complete). Creation still auto-syncs;
      # 'ws reset' is the deliberate re-convergence path.
      selfHeal: false
    syncOptions:
      - CreateNamespace=false
    retry:
      limit: 10
      backoff: {duration: 10s, factor: 2, maxDuration: 2m}
EOF
}

meta_list() {  # file top-level-key → list items (naive block-scoped YAML list read)
  # Block-scoped on purpose: ws-meta.yaml now holds MULTIPLE lists (purgeNamespaces,
  # conflictsWith) — a bare 'grep -- -' would cross-contaminate them.
  awk -v k="$2:" '
    $0 ~ "^"k {f=1; next}
    f && /^[[:space:]]*-[[:space:]]/ {s=$0; sub(/^[[:space:]]*-[[:space:]]*/,"",s); gsub(/"/,"",s); print s; next}
    f && /^[^[:space:]#]/ {f=0}
  ' "$1"
}

meta_namespaces() {  # module user → ws-meta purgeNamespaces with ${USER} resolved
  local meta="${ENTRY_DIR}/${1}/ws-meta.yaml" item
  [[ -f "$meta" ]] || return 0
  meta_list "$meta" purgeNamespaces | while read -r item; do echo "${item//\$\{USER\}/${2}}"; done
}

meta_conflicts() {  # module → ws-meta conflictsWith module list
  local meta="${ENTRY_DIR}/${1}/ws-meta.yaml"
  [[ -f "$meta" ]] || return 0
  meta_list "$meta" conflictsWith
}

meta_wait() {  # module → per-module sync-wait seconds (ws-meta waitSeconds); empty = engine default.
  # Modules whose hooks do real work (m07 solve runs a ~9-min pipeline) declare a longer window.
  local meta="${ENTRY_DIR}/${1}/ws-meta.yaml"
  [[ -f "$meta" ]] || return 0
  awk '$1=="waitSeconds:"{print $2; exit}' "$meta"
}

meta_smoke_cmds() {  # module → ws-meta smokeCommands list (OPTIONAL, default empty). Each entry is a
  # representative attendee command a module genuinely leans on (an in-terminal `mvn …`, an `argocd app
  # delete`); `ws smoke` runs each as {user} in the live cockpit and asserts exit 0. ${USER} is resolved
  # by the caller. The generic battery already catches most of the cockpit/identity class — declare only
  # 1–3 load-bearing commands (YAGNI).
  local meta="${ENTRY_DIR}/${1}/ws-meta.yaml"
  [[ -f "$meta" ]] || return 0
  meta_list "$meta" smokeCommands
}

meta_apps() {  # module user → "namespace project" if the module declares attendee-created Argo
  # Application CRs living OUTSIDE its purge namespaces (m09+: the student-gitops control plane —
  # ADR-0002 amendment 5: GitOps 1.21 refuses per-user source namespaces on a namespace-scoped
  # instance, so attendee apps live in the instance ns, isolated by Argo RBAC + AppProjects).
  # ws-meta keys: purgeAppsNamespace + purgeAppsProject (${USER} resolves).
  local meta="${ENTRY_DIR}/${1}/ws-meta.yaml" ns proj
  [[ -f "$meta" ]] || return 0
  ns="$(awk '$1=="purgeAppsNamespace:"{print $2; exit}' "$meta")"
  proj="$(awk '$1=="purgeAppsProject:"{print $2; exit}' "$meta")"
  [[ -n "$ns" && -n "$proj" ]] || return 0
  echo "${ns} ${proj//\$\{USER\}/${2}}"
}

purge_ns() {  # ns [keep-module] — delete user workloads/leftovers; preserve system objects
  # and ONLY the keep-module's entry marker. Preserving ALL ws-entry-* markers let stale
  # markers of long-gone modules survive every reset and false-green marker checks (G4-F9).
  local ns="$1" keep="${2:-}" kind name
  oc get ns "$ns" >/dev/null 2>&1 || return 0
  info "purging user workloads in ${ns}…"
  oc delete all,pvc --all -n "$ns" --wait=false >/dev/null 2>&1 || true
  # CRs 'oc delete all' misses: workspaces (M03+), Tekton runs (M07+), ImagePolicies (M08+) — extend
  # as modules add types. PipelineRuns cascade to their TaskRuns; deleting them also releases per-run
  # workspace PVCs. A leftover M08 ImagePolicy (block-unsigned) would otherwise block the next module's
  # image pulls in this namespace, so purge it too.
  oc delete devworkspaces.workspace.devfile.io --all -n "$ns" --wait=false >/dev/null 2>&1 || true
  oc delete pipelineruns.tekton.dev --all -n "$ns" --wait=false >/dev/null 2>&1 || true
  oc delete imagepolicies.config.openshift.io --all -n "$ns" --wait=false >/dev/null 2>&1 || true
  # PodDisruptionBudgets aren't in `oc delete all`; an attendee's leftover M12 PDB survives reset and
  # then trips the next start's entry verify (found at M12 G1, 2026-07-11).
  oc delete poddisruptionbudgets.policy --all -n "$ns" --wait=false >/dev/null 2>&1 || true
  # Same for the M12 attendee-created PrometheusRule — not in `oc delete all`, survives reset and red-
  # fails the next entry verify ("no PrometheusRule yet") (M12 G3, 2026-07-11 — sibling of the PDB gap).
  oc delete prometheusrules.monitoring.coreos.com --all -n "$ns" --wait=false >/dev/null 2>&1 || true
  # Secrets/ConfigMaps the user created (e.g. template-instantiated DB creds) leak past
  # 'oc delete all' — purge them EXCEPT system objects and the current module's marker.
  for kind in secret configmap; do
    for name in $(oc get "$kind" -n "$ns" -o name 2>/dev/null); do
      case "$name" in
        */builder-dockercfg-*|*/default-dockercfg-*|*/deployer-dockercfg-*|*/builder-token-*|*/default-token-*|*/deployer-token-*|*/kube-root-ca.crt|*/openshift-service-ca.crt) ;;
        */ws-entry-${keep}) [[ -n "$keep" ]] || oc delete "$name" -n "$ns" --wait=false >/dev/null 2>&1 || true;;
        */ws-entry-*) oc delete "$name" -n "$ns" --wait=false >/dev/null 2>&1 || true;;
        *) oc delete "$name" -n "$ns" --wait=false >/dev/null 2>&1 || true;;
      esac
    done
  done
  ok "purge requested in ${ns}"
}

# ── student-gitops attendee-app cleanup (SEV1-A) ──────────────────────────────────────────────────
# Attendee-created apps live in the student-gitops CONTROL PLANE, where attendees have ZERO k8s RBAC
# (only ARGO RBAC via proj-{user}, ADR-0002). So `oc delete application -n student-gitops` as an
# attendee is Forbidden and the old `2>/dev/null` swallowed it into a silent no-op — a selfHeal
# survivor (m09/m10 claims-*) then re-deployed into the just-purged namespace and prep/reset never
# converged (SEV1-A). We instead delete through the STUDENT ARGO API as the attendee: the per-user
# local account's token maps to role:{user} → proj-{user}, so Argo RBAC bounds every delete to the
# user's OWN apps (a cross-project delete returns permission denied — the SAME boundary M10's negative
# test proves). A namespace-wide k8s `delete applications` grant would be a cross-tenant hole and is
# deliberately NOT used. Admin/instructor keep the direct k8s path (they can delete cross-namespace).
_student_argo_host() {  # → student Argo server route host, derived from the ingress domain (attendee-
  # safe: attendees cannot read the student-gitops route cross-namespace — the verify scripts' idiom).
  local domain
  domain="$(oc get ingresses.config cluster -o jsonpath='{.spec.domain}' 2>/dev/null || true)"
  [[ -n "$domain" ]] || return 1
  echo "student-gitops-server-${STUDENT_ARGO_NS}.${domain}"
}
_shared_password() {  # → the SHARED workshop password (non-secret). WS_WORKSHOP_PASSWORD overrides
  # for CI; otherwise the gitea workshop-user-creds secret (workshop-config grants attendees a
  # resourceName-scoped read on JUST that secret — attendee-argo-password-read.yaml).
  if [[ -n "${WS_WORKSHOP_PASSWORD:-}" ]]; then printf '%s' "$WS_WORKSHOP_PASSWORD"; return 0; fi
  oc get secret workshop-user-creds -n "${GITEA_NS}" -o jsonpath='{.data.password}' 2>/dev/null | base64 -d
}
_json_escape() { local s="$1"; s="${s//\\/\\\\}"; s="${s//\"/\\\"}"; printf '%s' "$s"; }
_argo_token() {  # user → a student-Argo session JWT for the per-user local account, or empty on failure
  local user="$1" host pw
  host="$(_student_argo_host)" || return 1
  pw="$(_shared_password)"; [[ -n "$pw" ]] || return 1
  curl -ksf --max-time 15 -X POST "https://${host}/api/v1/session" \
    -H 'Content-Type: application/json' \
    -d "{\"username\":\"$(_json_escape "$user")\",\"password\":\"$(_json_escape "$pw")\"}" 2>/dev/null \
    | sed -n 's/.*"token":"\([^"]*\)".*/\1/p' | head -1
}
_argo_list() {  # host token kind proj → "name<TAB>module-label" per item in proj (Argo RBAC also filters)
  curl -ksf --max-time 15 "https://${1}/api/v1/${3}" -H "Authorization: Bearer ${2}" 2>/dev/null \
    | WS_PROJ="$4" python3 -c '
import json, os, sys
proj = os.environ["WS_PROJ"]
try:
    d = json.load(sys.stdin)
except Exception:
    sys.exit(0)
for it in (d.get("items") or []):
    spec = it.get("spec", {}) or {}
    p = spec.get("project") or ((spec.get("template", {}) or {}).get("spec", {}) or {}).get("project")
    if p != proj:
        continue
    md = it.get("metadata", {}) or {}
    lbl = (md.get("labels") or {}).get("workshop.redhat.com/module", "")
    print((md.get("name") or "") + "\t" + lbl)
' 2>/dev/null
}
argo_purge_apps() {  # user proj [keep] — delete the user's OWN proj apps/appsets via the student Argo
  # API. appsets FIRST (they regenerate deleted apps — M10 G1 flag #2). keep = a module label to
  # preserve (the TARGET's own chart apps on a bare re-start). Best-effort + non-fatal: a token or
  # reachability failure warns and returns (the k8s entry-app deletion still runs). Isolation is
  # enforced by Argo — this token cannot see, let alone delete, another user's apps.
  local user="$1" proj="$2" keep="${3:-}" host token name mod t=0
  host="$(_student_argo_host)" || { info "student Argo host unknown — skipping attendee-app cleanup (${proj})"; return 0; }
  curl -ksf --max-time 5 "https://${host}/healthz" >/dev/null 2>&1 \
    || { info "student Argo unreachable — skipping attendee-app cleanup (${proj})"; return 0; }
  token="$(_argo_token "$user")"
  [[ -n "$token" ]] || { err "could not authenticate ${user} to student Argo — attendee apps in ${proj} NOT cleaned"; \
    echo "   fix: workshop-config must grant attendees read on gitea/workshop-user-creds, or set WS_WORKSHOP_PASSWORD"; return 0; }
  while IFS=$'\t' read -r name mod; do
    [[ -n "$name" ]] || continue
    [[ -n "$keep" && "$mod" == "$keep" ]] && continue
    info "deleting attendee ApplicationSet ${name} (project ${proj}) via student Argo…"
    # Content-Type is REQUIRED even on a body-less DELETE — the Argo gRPC-gateway 415s without it
    # (the delete then silently no-ops and the survivor lives on — the exact SEV1-A failure mode).
    curl -ksf --max-time 30 -X DELETE "https://${host}/api/v1/applicationsets/${name}" \
      -H "Authorization: Bearer ${token}" -H 'Content-Type: application/json' >/dev/null 2>&1 || true
  done < <(_argo_list "$host" "$token" applicationsets "$proj")
  while IFS=$'\t' read -r name mod; do
    [[ -n "$name" ]] || continue
    [[ -n "$keep" && "$mod" == "$keep" ]] && continue
    info "deleting attendee Argo app ${name} (project ${proj}) via student Argo…"
    curl -ksf --max-time 30 -X DELETE "https://${host}/api/v1/applications/${name}?cascade=true" \
      -H "Authorization: Bearer ${token}" -H 'Content-Type: application/json' >/dev/null 2>&1 || true
  done < <(_argo_list "$host" "$token" applications "$proj")
  # Wait until the user's apps clear (cascade prune honors the resources-finalizer) so the caller's
  # namespace purge does not race a still-selfHealing app. Bounded + non-fatal: issuing the DELETE
  # already stops selfHeal; the wait just lets the finalizer prune claims before purge_ns runs.
  while (( t < 90 )); do
    [[ -n "$(_argo_list "$host" "$token" applications "$proj")" ]] || break
    sleep 5; t=$((t+5))
  done
}

purge_apps() {  # module user [keep-module] — delete the user's Application/ApplicationSet CRs for this
  # module's control plane (ws-meta purgeApps*). These live OUTSIDE the module's purge namespaces, so
  # purge_ns never sees them; selected by .spec.project (proj-{user}). keep-module (M10 G1 engine flag
  # #1): a module's OWN chart apps carry workshop.redhat.com/module=<module> and share proj-{user} with
  # a conflicting module's — on a bare re-start gc must not purge the TARGET's own world. Admin/
  # instructor delete via k8s directly; attendees (no k8s RBAC here) delete via the student Argo API,
  # bounded to proj-{user} by Argo RBAC (SEV1-A — see argo_purge_apps).
  local module="$1" user="$2" keep="${3:-}" pair ns proj name mod
  pair="$(meta_apps "$module" "$user")"
  [[ -n "$pair" ]] || return 0
  ns="${pair%% *}"; proj="${pair##* }"
  if ! oc auth can-i delete applications.argoproj.io -n "$ns" >/dev/null 2>&1; then
    # Attendee: no k8s delete in the control plane → go through Argo (proj-scoped, isolation-safe).
    argo_purge_apps "$user" "$proj" "$keep"
    return 0
  fi
  # Privileged (admin/instructor) k8s path. ApplicationSets FIRST: an attendee's appset (M10 beat 1)
  # re-generates any Application we delete, so purging apps before their generator is self-defeating.
  for name in $(oc get applicationsets.argoproj.io -n "$ns" \
      -o jsonpath="{range .items[?(@.spec.template.spec.project==\"${proj}\")]}{.metadata.name}{\"\n\"}{end}" 2>/dev/null); do
    if [[ -n "$keep" ]]; then
      mod="$(oc get applicationset "$name" -n "$ns" -o jsonpath='{.metadata.labels.workshop\.redhat\.com/module}' 2>/dev/null || true)"
      [[ "$mod" == "$keep" ]] && continue
    fi
    info "deleting attendee ApplicationSet ${ns}/${name} (project ${proj})…"
    oc delete applicationset "$name" -n "$ns" --wait=true --timeout=120s >/dev/null 2>&1 || true
  done
  for name in $(oc get applications.argoproj.io -n "$ns" \
      -o jsonpath="{range .items[?(@.spec.project==\"${proj}\")]}{.metadata.name}{\"\n\"}{end}" 2>/dev/null); do
    if [[ -n "$keep" ]]; then
      mod="$(oc get application "$name" -n "$ns" -o jsonpath='{.metadata.labels.workshop\.redhat\.com/module}' 2>/dev/null || true)"
      [[ "$mod" == "$keep" ]] && continue
    fi
    info "deleting attendee Argo app ${ns}/${name} (project ${proj})…"
    oc delete application "$name" -n "$ns" --wait=true --timeout=120s >/dev/null 2>&1 \
      || oc patch application "$name" -n "$ns" --type merge -p '{"metadata":{"finalizers":null}}' >/dev/null 2>&1 || true
  done
}

gc_conflicts() {  # user module — evict conflicting modules' entry apps before materializing
  # Module independence (rule 2): entry charts that materialize the SAME named workloads
  # (declared in ws-meta conflictsWith) deadlock when their Argo apps coexist — both go
  # OutOfSync on SharedResourceWarning and the attendee gets a silently wrong world while
  # the marker check stays green (G3-M04, m03+m04 on user3). Starting a module therefore
  # evicts the conflicting app and purges this module's namespaces (= reset semantics).
  # Disjoint modules (m01 parasol-web, m06 {user}-batch) still coexist untouched.
  local user="$1" module="$2" evicted=0 c app ns
  for c in $(meta_conflicts "$module"); do
    app="$(app_name "$c" "$user")"
    if oc get application "$app" -n "$ARGO_NS" >/dev/null 2>&1; then
      info "evicting conflicting entry app ${app} (shares workloads with ${module})…"
      oc delete application "$app" -n "$ARGO_NS" --wait=true --timeout=180s || true
      evicted=1
    else
      # The conflicting module's app may be long gone while its ORPHANED leftovers still
      # squat in our namespaces (bare 'oc delete application' skips the purge — G4-F3:
      # start over such leftovers produced a wrong entry state behind partly-green checks).
      # A surviving marker is the tell — trigger the purge path even with no app to evict.
      for ns in $(meta_namespaces "$module" "$user"); do
        if oc get cm "ws-entry-${c}" -n "$ns" >/dev/null 2>&1; then
          info "found orphaned ${c} leftovers in ${ns} (marker, no app) — reclaiming…"
          evicted=1; break
        fi
      done
    fi
    # The conflicting module's attendee-created Argo apps (ws-meta purgeApps*) live in a
    # control-plane ns and would keep selfHeal-ing its world back — purge them regardless
    # of whether the entry app itself was still present. Keep the TARGET module's own
    # chart-labeled apps: on a bare re-start nothing recycles the entry app, so purging
    # its world would wipe it permanently (M10 G1 flag #1).
    purge_apps "$c" "$user" "$module"
  done
  if [[ "$evicted" == 1 ]]; then
    for ns in $(meta_namespaces "$module" "$user"); do purge_ns "$ns" "$module"; done
    # The purge also removed THIS module's chart-owned resources if its app pre-existed.
    # With selfHeal off, re-applying an UNCHANGED app never re-syncs them — recycle the
    # app so the fresh apply is a creation, which always auto-syncs.
    app="$(app_name "$module" "$user")"
    oc delete application "$app" -n "$ARGO_NS" --wait=true --timeout=180s >/dev/null 2>&1 || true
  fi
}

wait_healthy() {  # appname [timeout_s]
  local app="$1" timeout="${2:-300}" t=0 health sync phase empty_ok=0
  info "waiting for ${app} to sync (up to ${timeout}s)…"
  while (( t < timeout )); do
    health="$(oc get application "$app" -n "$ARGO_NS" -o jsonpath='{.status.health.status}' 2>/dev/null || true)"
    sync="$(oc get application "$app" -n "$ARGO_NS" -o jsonpath='{.status.sync.status}' 2>/dev/null || true)"
    # Hooks keep the sync OPERATION Running after the app already reads Synced/Healthy — and a
    # solve hook that does real work (m07: runs the whole pipeline) is exactly the point. Ready
    # means the operation finished too, or "demo-ready" prints while the namespace is still empty.
    phase="$(oc get application "$app" -n "$ARGO_NS" -o jsonpath='{.status.operationState.phase}' 2>/dev/null || true)"
    if [[ "$health" == "Healthy" && "$sync" == "Synced" ]]; then
      if [[ "$phase" == "Succeeded" ]]; then
        ok "entry state ready (Synced/Healthy)"
        return 0
      fi
      # Empty phase can be a transient window BETWEEN hook retries (M10 G1 flag #3: a failing
      # PostSync hook briefly reads Synced/Healthy/no-op) — accept it only after it HOLDS.
      if [[ -z "$phase" ]]; then
        empty_ok=$((empty_ok+1))
        if (( empty_ok >= 3 )); then
          ok "entry state ready (Synced/Healthy)"
          return 0
        fi
      else
        empty_ok=0
      fi
    else
      empty_ok=0
    fi
    sleep 5; t=$((t+5))
  done
  err "entry state not ready after ${timeout}s (health=${health:-?} sync=${sync:-?} op=${phase:-?})"
  echo "   inspect: oc describe application ${app} -n ${ARGO_NS}"
  return 1
}

cmd_list() {
  heal_if_behind   # a just-published module should list here without a pod restart (mirror-clone only)
  echo "Modules with entry states:"
  local found=0
  for d in "${ENTRY_DIR}"/m*/; do
    [[ -d "$d" ]] || continue
    found=1
    local m desc
    m="$(basename "$d")"
    desc="$(grep -m1 '^description:' "${d}Chart.yaml" 2>/dev/null | sed 's/description:[[:space:]]*//' || true)"
    printf "  %-6s %s\n" "$m" "${desc:-—}"
  done
  [[ "$found" == 1 ]] || echo "  (none yet)"
}

cmd_start() {
  local module user="$1" ; module="$2"
  need_oc
  require_entry_dir "$module"
  # --all-users: instructor convenience — entry states are provisioned by instructors/automation
  # (attendees lack Application-create rights on the platform Argo instance by design, ADR-0002).
  if [[ "$user" == "--all-users" || "$user" == "all" ]]; then
    local n
    n="$(oc get group workshop-attendees -o jsonpath='{.users[*]}' 2>/dev/null | wc -w | xargs)"
    [[ "$n" -gt 0 ]] || die "cannot enumerate workshop-attendees group"
    info "materializing ${module} for all ${n} attendees…"
    for u in $(oc get group workshop-attendees -o jsonpath='{.users[*]}'); do
      gc_conflicts "$u" "$module"
      render_app "$module" "$u" | oc apply -f - >/dev/null
      echo "  ✓ ${u}"
    done
    ok "entry apps applied for ${n} users — sync continues in-cluster (watch: oc get applications -n ${ARGO_NS})"
    return 0
  fi
  gc_conflicts "$user" "$module"
  info "materializing ${module} entry state for ${user}…"
  render_app "$module" "$user" | oc apply -f -
  # Spec changes on an EXISTING app (e.g. solve->start) can serve Argo's cached manifests;
  # force a re-render + real operation (M11 G1: solve materialized only after refresh+sync).
  sync_app_operation "$(app_name "$module" "$user")"
  wait_healthy "$(app_name "$module" "$user")" "$(meta_wait "$module")"
  echo
  ok "${user} can start ${module}."
}

cmd_prep() {  # ATTENDEE self-service (project directive 2026-07-10): attendees forget to wipe the
  # previous module before starting the next, and prep must never depend on an instructor.
  # Detect what's in the user's world, say it plainly, ask consent, then run the proven
  # purge-first reset path. Requires the per-user Argo RBAC from the workshop layer
  # (gitops/workshop-config/templates/per-user-argo-rbac.yaml).
  local module user="$1"; module="$2"; shift 2 || true
  local yes="false"
  [[ "${1:-}" == "--yes" || "${1:-}" == "-y" ]] && yes="true"
  need_oc
  require_entry_dir "$module"
  local app; app="$(app_name "$module" "$user")"

  info "checking your ${module} environment (${user})…"
  local findings=() ns c capp
  # 1. Leftovers from OTHER modules in the namespaces this module owns/purges.
  for ns in $(meta_namespaces "$module" "$user"); do
    oc get ns "$ns" >/dev/null 2>&1 || continue
    local foreign
    foreign="$(oc get cm -n "$ns" -o name 2>/dev/null | sed -n 's|configmap/ws-entry-||p' | grep -v "^${module}\$" || true)"
    [[ -n "$foreign" ]] && findings+=("${ns} still holds state from module(s): $(echo "$foreign" | tr '\n' ' ')")
    local workloads
    workloads="$(oc get deploy,statefulsets,jobs,cronjobs -n "$ns" --no-headers 2>/dev/null | wc -l | tr -d ' ')"
    [[ "$workloads" -gt 0 && -z "$(oc get cm "ws-entry-${module}" -n "$ns" -o name 2>/dev/null)" ]] \
      && findings+=("${ns} has ${workloads} workload(s) but no ${module} marker")
  done
  # 2. Conflicting modules' entry apps still live (would deadlock this module's world).
  for c in $(meta_conflicts "$module"); do
    capp="$(app_name "$c" "$user")"
    oc get application "$capp" -n "$ARGO_NS" >/dev/null 2>&1 && findings+=("conflicting module ${c} is still provisioned (${capp})")
  done
  # 3. The module's own state: app + marker + entry verify.
  local have_app="false"
  oc get application "$app" -n "$ARGO_NS" >/dev/null 2>&1 && have_app="true"
  if [[ "$have_app" == "true" && ${#findings[@]} -eq 0 ]]; then
    local script="${VERIFY_DIR}/${module}.sh"
    if [[ -x "$script" ]] && "$script" --user "$user" --entry-only >/dev/null 2>&1; then
      ok "your ${module} environment is already prepared — nothing to do."
      echo "   (want a factory-fresh copy anyway? re-run with: ws prep ${module} --yes)"
      [[ "$yes" != "true" ]] && return 0
      findings+=("re-prep requested with --yes")
    else
      findings+=("${module} is provisioned but its entry checks are not passing")
    fi
  fi
  [[ "$have_app" == "false" ]] && findings+=("${module} is not provisioned for ${user} yet")

  echo
  echo "Found:"
  local f; for f in "${findings[@]}"; do echo "  • $f"; done
  echo
  echo "Preparing ${module} will WIPE the leftovers above (your namespaces are purged and"
  echo "re-materialized; anything you built in them is deleted) and set up a clean ${module} world."
  if [[ "$yes" != "true" ]]; then
    if [[ -t 0 ]]; then
      local reply
      read -r -p "Wipe and prepare ${module} now? [y/N] " reply
      [[ "$reply" =~ ^[Yy]([Ee][Ss])?$ ]] || { info "nothing changed. Re-run when ready (or use --yes)."; return 0; }
    else
      die "not a terminal and no --yes given — re-run: ws prep ${module} --yes"
    fi
  fi

  cmd_reset "$user" "$module"
  echo
  local script="${VERIFY_DIR}/${module}.sh"
  if [[ -x "$script" ]]; then
    if "$script" --user "$user" --entry-only; then
      ok "${module} is ready — start the lab."
    else
      info "setup hooks may still be settling (seeding data takes up to ~1 min) — re-check with: ws verify ${module}"
    fi
  fi
}

cmd_verify() {
  local module user="$1"; module="$2"; shift 2 || true
  need_oc
  require_verify_script "$module"
  local script="${VERIFY_DIR}/${module}.sh"
  "$script" --user "$user" "$@"
}

# ── ws smoke — the G1 attendee-cockpit gate ───────────────────────────────────────────────────────
# Runs the attendee path FROM the real cockpit terminal as {user} (never the admin kubeconfig), to
# catch the recurring cockpit/identity defect class (ws-not-on-PATH, HOME=/data, JVM user.home,
# isolation leaks, stale-pod, prep/verify RBAC) at the CHEAPEST gate. See docs/plans/2026-07-12-
# cockpit-smoke-gate-design.md.
smoke_pod() {  # user ns → newest Running showroom terminal pod name (bare, no pod/ prefix), or empty
  local p
  p="$(oc get pods -n "$2" -l "app.kubernetes.io/name=showroom,workshop.redhat.com/user=${1}" \
        --field-selector=status.phase=Running --sort-by=.metadata.creationTimestamp -o name 2>/dev/null | tail -1)"
  echo "${p#pod/}"
}
# pod_i: run a command EXACTLY as the attendee does — an INTERACTIVE ttyd shell that sources ~/.bashrc,
# so `ws` is on PATH and the oc identity is {user}. A bare (non-interactive) exec would MISS the PATH
# export (skel .bashrc early-returns for non-interactive shells) — that is a test artifact, not the
# attendee's reality; the whole point of the gate is to test the interactive path. The greeting/MOTD
# .bashrc prints lands on stdout but never enters a command's pipeline, and `check` discards stdout.
pod_i() { oc exec "$SMOKE_POD" -n "$SMOKE_NS" -c "$SMOKE_CONTAINER" -- bash -ic "$1"; }
# pod_x: bare (non-interactive) exec — no ~/.bashrc, no greeting; for CLEAN captures (e.g. clone HEAD).
pod_x() { oc exec "$SMOKE_POD" -n "$SMOKE_NS" -c "$SMOKE_CONTAINER" -- bash -c "$1"; }

# SC2016 is disabled for this whole function ON PURPOSE: the single-quoted $HOME/$uh/$(…) inside the
# pod_i/pod_x command strings must stay UNEXPANDED host-side and evaluate in the attendee's pod shell.
# shellcheck disable=SC2016
cmd_smoke() {
  local module user="$1"; module="$2"; shift 2 || true
  # Accept a positional userN (ws smoke m09 user1) in addition to --user, resolved like other verbs.
  local a
  for a in "$@"; do [[ "$a" =~ ^user[0-9]+$ ]] && user="$a"; done
  need_oc
  # Reuse the verify scripts' ✅/❌ + hint idiom verbatim (check/hint/VERIFY_PASS/VERIFY_FAIL).
  # shellcheck disable=SC1091  # _lib.sh is linted standalone; its path is runtime-derived
  source "${VERIFY_DIR}/_lib.sh"

  SMOKE_NS="$SHOWROOM_NS"
  SMOKE_POD="$(smoke_pod "$user" "$SMOKE_NS")"
  [[ -n "$SMOKE_POD" ]] || die "no Running showroom cockpit for ${user} in ns ${SMOKE_NS} — provision the session first (oc get pods -n ${SMOKE_NS} -l workshop.redhat.com/user=${user})"
  info "smoke ${module} from ${user}'s cockpit (pod ${SMOKE_POD}) — running the attendee path as ${user}…"
  echo

  # ── identity & environment (the cockpit-identity class) ─────────────────────────────────────────
  check "ws is on the attendee's interactive PATH (as typed in ttyd)" pod_i 'command -v ws' \
    || hint "ws missing from the interactive PATH — check the WS_WORKSHOP_PROFILE block in ~/.bashrc (showroom terminal-prep)"
  check "\$HOME is /home/lab-user (persistent PVC, not /data)" pod_i '[[ "$HOME" == /home/lab-user ]]' \
    || hint "terminal HOME wrong — the showroom terminal container needs env HOME=/home/lab-user"
  check "JVM user.home == \$HOME (Maven/.m2 not stranded on /data)" pod_i 'uh=$(java -XshowSettings:properties 2>&1 | sed -n "s/^.*user\.home = //p" | tr -d "[:space:]"); [[ -n "$uh" && "$uh" == "$HOME" ]]' \
    || hint "passwd home != \$HOME — the terminal postStart must rewrite /etc/passwd home to /home/lab-user (the JVM reads user.home from passwd, not \$HOME)"
  check "shell identity is ${user} (not the showroom ServiceAccount)" pod_i "[[ \"\$(oc whoami 2>/dev/null)\" == \"${user}\" ]]" \
    || hint "terminal is not logged in as ${user} — terminal-prep's oc login failed; inspect the showroom pod"
  check "attendee is NOT cluster-admin (no privileged context reachable)" pod_i '! oc auth can-i "*" "*" --all-namespaces --quiet 2>/dev/null' \
    || hint "attendee has cluster-admin rights — a privileged-context leak; the cockpit must run as the unprivileged {user}"

  # ── isolation (attendee sees ONLY their own world) ──────────────────────────────────────────────
  check "peer projects invisible (own namespaces only)" pod_i "oc get projects -o name 2>/dev/null | sed 's#.*/##' | grep -E '^user[0-9]+-' | grep -vq '^${user}-' && exit 1 ; exit 0" \
    || hint "attendee can see another user's namespaces — a per-user RBAC leak (workshop-config per-user rolebindings)"
  check "system 'openshift' project invisible to the attendee" pod_i '! oc get project openshift >/dev/null 2>&1' \
    || hint "attendee can read the openshift project — namespace isolation leak"
  check "cluster-scope 'oc get namespaces' is Forbidden" pod_i '! oc get namespaces >/dev/null 2>&1' \
    || hint "attendee can list all namespaces cluster-wide — a cluster-scope RBAC leak"

  # ── freshness (the stale-pod class: a cockpit serving content behind the mirror) ────────────────
  local want have
  want="$(mirror_head || true)"
  have="$(pod_x 'git -C "$HOME/ocp-getting-started" rev-parse HEAD 2>/dev/null' 2>/dev/null | tr -d '[:space:]' || true)"
  if [[ -z "$want" ]]; then
    info "mirror HEAD unreadable (gitea down?) — skipping the freshness check"
  else
    check "cockpit clone HEAD matches the mirror (${want:0:8})" test "$have" = "$want" \
      || hint "pod serves ${have:0:8}, mirror ${want:0:8} — a stale cockpit: ws git-refresh --restart-terminals --user ${user}"
  fi

  # ── lifecycle FROM the cockpit (the attendee's real prep/verify entrypoints) ────────────────────
  check "ws prep ${module} converges from the cockpit (attendee self-service)" pod_i "ws prep ${module}" \
    || hint "attendee 'ws prep ${module}' did not converge — materialize it first: ws prep ${module} --user ${user}, then re-smoke"
  # --entry-only on purpose: the smoke targets a freshly-materialized ENTRY state; a completed lab's
  # END checks legitimately go red on an entry state (verify scripts are mode-split, template rule 14).
  check "ws verify ${module} --entry-only passes N/N in the cockpit" pod_i "ws verify ${module} --entry-only" \
    || hint "entry checks are red in the cockpit — inspect: ws verify ${module} --user ${user}"

  # ── per-module hook: representative click-to-run blocks (ws-meta smokeCommands, optional) ────────
  local sc had_sc=0
  while IFS= read -r sc; do
    [[ -n "$sc" ]] || continue
    had_sc=1
    sc="${sc//\$\{USER\}/${user}}"
    check "smokeCommand: ${sc}" pod_i "$sc" \
      || hint "a representative attendee command failed in the cockpit — run it in ${user}'s terminal to debug"
  done < <(meta_smoke_cmds "$module")
  [[ "$had_sc" == 1 ]] || info "(no ws-meta smokeCommands for ${module} — generic battery only)"

  # ── summary (N/N, non-zero exit on any failure so the gate can fail CI/agent briefs) ────────────
  echo
  local total=$((VERIFY_PASS + VERIFY_FAIL))
  if (( VERIFY_FAIL == 0 )); then
    ok "smoke ${module} @ ${user}: ${VERIFY_PASS}/${total} attendee-cockpit checks passed"
  else
    err "smoke ${module} @ ${user}: ${VERIFY_FAIL} of ${total} attendee-cockpit checks FAILED — do not pass G1 until green"
    exit 1
  fi
}

cmd_reset() {
  local module user="$1"; module="$2"
  need_oc
  local app; app="$(app_name "$module" "$user")"
  info "resetting ${module} for ${user} (purge + delete + re-materialize)…"

  # Purge FIRST — this ordering is load-bearing (G3-M06 SEV1). Attendee-created workloads (Jobs/
  # pods the entry app does NOT own) can pin a chart-owned PVC through kubernetes.io/pvc-protection.
  # If we delete the Application first, its resources-finalizer blocks indefinitely trying to prune
  # that PVC while the pods holding it are never removed (they aren't app-owned), and the purge that
  # WOULD remove them never runs. Purging first deletes those pods (Completed pods drain in ~1s),
  # releases the PVC, and empties the namespace; with selfHeal:false the still-present app never
  # re-creates what we delete (it only marks OutOfSync). This also hardens m05's StatefulSet reset,
  # where volumeClaimTemplate PVCs are pinned the same way.
  # Attendee-created Argo apps FIRST (ws-meta purgeApps*): they live outside the purge namespaces,
  # and a selfHeal app re-deploys its workloads DURING the namespace purge and orphans them if the
  # purge runs first (reproduced live, M09 G1 — gc_conflicts always had this order; reset now matches).
  purge_apps "$module" "$user"
  local ns
  for ns in $(meta_namespaces "$module" "$user"); do purge_ns "$ns" "$module"; done

  # Now remove the GitOps wrapper. With the namespace already emptied the finalizer has little or
  # nothing left to prune and completes fast; if it still lingers, strip the finalizer rather than
  # fail the reset — the manual purge already did the pruning the finalizer exists to do.
  if oc get application "$app" -n "$ARGO_NS" >/dev/null 2>&1; then
    if ! oc delete application "$app" -n "$ARGO_NS" --wait=true --timeout=120s; then
      info "finalizer still settling — namespace already purged, removing it…"
      oc patch application "$app" -n "$ARGO_NS" --type=json \
        -p '[{"op":"remove","path":"/metadata/finalizers"}]' >/dev/null 2>&1 || true
      local t=0
      while oc get application "$app" -n "$ARGO_NS" >/dev/null 2>&1; do
        (( t >= 60 )) && die "entry app ${app} stuck deleting — inspect: oc get application ${app} -n ${ARGO_NS} -o yaml (finalizers)"
        sleep 3; t=$((t+3))
      done
    fi
    ok "chart-owned state pruned"
  else
    info "no existing entry app — clean start"
  fi
  cmd_start "$user" "$module"
}

cmd_solve() {  # instructor: materialize the module END state (entry chart with solve=true)
  local module user="$1"; module="$2"
  need_oc
  require_entry_dir "$module"
  grep -q '^solve:' "${ENTRY_DIR}/${module}/values.yaml" 2>/dev/null \
    || die "${module}'s chart defines no solve state (values.yaml lacks 'solve:')"
  gc_conflicts "$user" "$module"
  info "materializing ${module} END state for ${user} (instructor solve)…"
  render_app "$module" "$user" "true" | oc apply -f -
  # solve flips a helm parameter on an EXISTING app — without a hard-refresh + operation Argo
  # can serve the cached solve=false render and "solve" becomes a silent no-op (M11 G1 flag #1).
  sync_app_operation "$(app_name "$module" "$user")"
  wait_healthy "$(app_name "$module" "$user")" "$(meta_wait "$module")"
  echo
  ok "${module} solved for ${user} — demo-ready."
}

sync_app_operation() {  # app — start a fresh sync OPERATION (hooks only re-run on operations;
  # a refresh alone re-compares but re-fires nothing — proven painfully 2026-07-10). Waits out a
  # running operation first (patching .operation while one runs is silently swallowed), and
  # hard-refreshes so Argo re-resolves the branch (cached revisions otherwise sync stale).
  local app="$1" t=0 ph
  while (( t < 300 )); do
    ph="$(oc get application "$app" -n "$ARGO_NS" -o jsonpath='{.status.operationState.phase}' 2>/dev/null || true)"
    [[ "$ph" != "Running" && "$ph" != "Terminating" ]] && break
    sleep 5; t=$((t+5))
  done
  oc annotate application "$app" -n "$ARGO_NS" argocd.argoproj.io/refresh=hard --overwrite >/dev/null 2>&1 || true
  sleep 10
  if oc patch application "$app" -n "$ARGO_NS" --type merge \
    -p '{"operation":{"initiatedBy":{"username":"ws-git-refresh"},"sync":{"revision":"main"}}}' >/dev/null 2>&1; then
    ok "sync operation started on ${app}"
  else
    err "could not start a sync on ${app} (still busy?) — retry shortly"
  fi
}

# Force the in-cluster Gitea pull-mirror to fetch origin NOW and WAIT until it actually serves the
# pushed HEAD. The mirror-sync hook fires on a pp-git-mirror sync, but Gitea's pull is async and the
# sync op returns before it finishes — so a just-pushed commit can lag minutes and every entry app
# then syncs STALE content (repeatedly cost real time; G3-M11 fix-round find, 2026-07-11). This POSTs
# mirror-sync directly (bootstrap's admin-cred pattern) and polls the mirror branch HEAD to origin's.
force_mirror_sync() {
  local host user pass target mirror
  host="$(oc get route gitea -n "${GITEA_NS}" -o jsonpath='{.spec.host}' 2>/dev/null || true)"
  [[ -n "$host" ]] || { echo "⚠ gitea route not found — skipping mirror-sync (will refresh on interval)"; return 0; }
  user="$(oc get gitea gitea -n "${GITEA_NS}" -o jsonpath='{.spec.giteaAdminUser}' 2>/dev/null || echo gitea-admin)"
  pass="$(oc get gitea gitea -n "${GITEA_NS}" -o jsonpath='{.status.adminPassword}' 2>/dev/null || true)"
  [[ -z "$pass" ]] && pass="$(oc get secret gitea-admin-credentials -n "${GITEA_NS}" -o jsonpath='{.data.password}' 2>/dev/null | base64 -d || true)"
  [[ -n "$pass" ]] || { echo "⚠ no Gitea admin password — mirror will refresh on its own interval"; return 0; }
  curl -ksf -u "${user}:${pass}" -X POST \
    "https://${host}/api/v1/repos/${MIRROR_ORG}/${MIRROR_REPO}/mirror-sync" >/dev/null 2>&1 || true
  # Target = what origin actually serves after your push (the mirror pulls from there).
  target="$(git -C "$REPO_ROOT" rev-parse origin/main 2>/dev/null || true)"
  [[ -n "$target" ]] || { info "mirror-sync triggered (no local origin/main ref to wait on)"; return 0; }
  for _ in $(seq 1 30); do
    mirror="$(curl -ksf "https://${host}/api/v1/repos/${MIRROR_ORG}/${MIRROR_REPO}/branches/main" 2>/dev/null \
      | sed -n 's/.*"id":"\([a-f0-9]*\)".*/\1/p' | head -1)"
    [[ "$mirror" == "$target" ]] && { ok "mirror at ${target:0:8} (matches origin)"; return 0; }
    sleep 4
  done
  echo "⚠ mirror still behind origin after ~2m (at ${mirror:0:8}); entry apps may briefly serve stale content"
}

verify_terminal_head() {  # user ns want-sha — confirm the FRESH pod re-cloned to current content (Part 2c)
  local u="$1" ns="$2" want="$3" pod clone_head
  pod="$(oc get pods -n "$ns" -l "app.kubernetes.io/name=showroom,workshop.redhat.com/user=${u}" \
           --field-selector=status.phase=Running --sort-by=.metadata.creationTimestamp -o name 2>/dev/null | tail -1)"
  pod="${pod#pod/}"
  [[ -n "$pod" ]] || { info "  ${u}: restarted (new pod not resolvable yet to verify clone)"; return 0; }
  clone_head="$(oc exec "$pod" -n "$ns" -c terminal -- git -C /home/lab-user/ocp-getting-started rev-parse HEAD 2>/dev/null || true)"
  if [[ -z "$clone_head" ]]; then
    info "  ${u}: restarted (clone HEAD not readable yet — pod still initializing)"
  elif [[ -n "$want" && "$clone_head" != "$want" ]]; then
    err "  ${u}: pod re-cloned to ${clone_head:0:8} but mirror serves ${want:0:8} — mirror lag? re-check shortly"
  else
    ok "  ${u}: pod re-cloned to ${clone_head:0:8}${want:+ (matches mirror)}"
  fi
}

restart_terminals() {  # target all-flag [exclude...] — opt-in restart of showroom cockpit pods so LIVE
  # attendees get re-rendered pages + re-cloned content. Rendered lab pages build at pod-init from the
  # mirror, so the CLI self-heal can't touch them — only a pod restart re-renders them. Reserved sessions
  # (WS_RESERVED_USERS, default 'user5' = the project owner's live test) are NEVER cycled by --all;
  # restarting one requires naming it with --user (i.e. with intent).
  local target="$1" all="$2"; shift 2
  local excludes=("$@")
  local ns="${WS_SHOWROOM_NS:-showroom}"
  local reserved=" ${WS_RESERVED_USERS:-user5} "
  local users=() u x skip
  if [[ -n "$target" ]]; then
    users=("$target")
    [[ "$reserved" == *" ${target} "* ]] && err "⚠ ${target} is a RESERVED live session — restarting it because you named it explicitly."
  elif [[ "$all" == true ]]; then
    for u in $(oc get deploy -n "$ns" -l app.kubernetes.io/name=showroom \
                 -o jsonpath='{range .items[*]}{.metadata.labels.workshop\.redhat\.com/user}{"\n"}{end}' 2>/dev/null | sort -u); do
      [[ -n "$u" ]] || continue
      [[ "$reserved" == *" ${u} "* ]] && { info "skipping reserved session ${u} (override with: --user ${u})"; continue; }
      skip=false
      if [[ ${#excludes[@]} -gt 0 ]]; then
        for x in "${excludes[@]}"; do [[ "$u" == "$x" ]] && skip=true; done
      fi
      [[ "$skip" == true ]] && { info "skipping ${u} (excluded)"; continue; }
      users+=("$u")
    done
    [[ ${#users[@]} -gt 0 ]] || die "no showroom sessions to restart in ns ${ns} (after reserved/exclusions)"
  else
    die "restart needs a target: --user <u> (one session) or --all (whole cohort, minus reserved ${WS_RESERVED_USERS:-user5})"
  fi

  info "restarting showroom terminal(s): ${users[*]}"
  local want; want="$(mirror_head || true)"
  local failed=0 dep
  for u in "${users[@]}"; do
    dep="showroom-${u}"
    if ! oc get deploy "$dep" -n "$ns" >/dev/null 2>&1; then
      err "  ${dep} not found in ${ns} — skipping"; failed=1; continue
    fi
    info "  ${dep}: rollout restart…"
    if ! oc rollout restart "deployment/${dep}" -n "$ns" >/dev/null 2>&1; then
      err "  ${dep}: restart failed (RBAC? this is an operator/admin action)"; failed=1; continue
    fi
    if ! oc rollout status "deployment/${dep}" -n "$ns" --timeout=180s >/dev/null 2>&1; then
      err "  ${dep}: not ready in 180s — check: oc rollout status deployment/${dep} -n ${ns}"; failed=1; continue
    fi
    verify_terminal_head "$u" "$ns" "$want"
  done
  echo
  if (( failed == 0 )); then
    ok "showroom terminal(s) restarted — attendees now see refreshed pages + content."
  else
    err "some restarts had issues — see above"; return 1
  fi
}

cmd_git_refresh() {
  need_oc
  local do_restart=false all=false target="" excludes=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --restart-terminals|--restart) do_restart=true; shift;;
      --all)                         all=true; shift;;
      --user)                        target="$2"; shift 2;;
      --exclude)                     excludes+=("$2"); shift 2;;
      *) die "git-refresh: unknown option '$1' — see: ws help";;
    esac
  done
  # Three layers pull from git: the Gitea pull-mirror (must fetch origin — force + wait FIRST, else
  # the two apps below sync stale content), then pp-git-mirror and workshop-config (whose Sync hooks
  # re-run the user seed AND the app-repo seed — the parasol/* app repos only refresh through THAT
  # hook). The apps need a real sync operation; no argocd CLI dependence (a stale CLI failed silently).
  info "forcing the Gitea pull-mirror to fetch your latest push…"
  force_mirror_sync
  info "re-running the git-localize mirror sync…"
  sync_app_operation pp-git-mirror
  info "re-running the workshop-config seed hooks (user seed + app-repo seed)…"
  sync_app_operation workshop-config
  echo "   watch: oc get jobs -n ${GITEA_NS} -w"
  # Opt-in ONLY: refresh what attendees READ. Bare `ws git-refresh` stays non-disruptive (mirror+Argo
  # only) — build agents call it constantly, and it must never nuke live sessions. Pods cycle solely
  # when --restart-terminals is given, and even then --all spares reserved sessions.
  if [[ "$do_restart" == true ]]; then
    echo
    if [[ ${#excludes[@]} -gt 0 ]]; then
      restart_terminals "$target" "$all" "${excludes[@]}"
    else
      restart_terminals "$target" "$all"
    fi
  elif [[ "$all" == true || -n "$target" || ${#excludes[@]} -gt 0 ]]; then
    info "note: --user/--all/--exclude take effect only with --restart-terminals (bare git-refresh never restarts pods)."
  fi
}

cmd_doctor() {
  need_oc
  echo "ws doctor — environment sanity"
  local fail=0
  printf "  %-28s" "cluster login"
  if oc whoami >/dev/null 2>&1; then ok "$(oc whoami) @ $(oc whoami --show-server)"; else err "not logged in"; fail=1; fi
  printf "  %-28s" "gitops operator"
  local csv
  csv="$(oc get csv -n openshift-gitops-operator -o jsonpath='{.items[?(@.spec.displayName=="Red Hat OpenShift GitOps")].status.phase}' 2>/dev/null || true)"
  if [[ "$csv" == *Succeeded* ]]; then ok "installed"; else err "not ready (${csv:-missing})"; fail=1; fi
  printf "  %-28s" "argo applications"
  local bad
  bad="$(oc get applications -n "$ARGO_NS" -o jsonpath='{range .items[*]}{.metadata.name}={.status.health.status} {end}' 2>/dev/null | tr ' ' '\n' | grep -v '=Healthy' | grep -v '^$' || true)"
  if [[ -z "$bad" ]]; then ok "all Healthy"; else err "unhealthy: $(echo "$bad" | tr '\n' ' ')"; fail=1; fi
  printf "  %-28s" "gitea"
  local host
  host="$(oc get route gitea -n "$GITEA_NS" -o jsonpath='{.spec.host}' 2>/dev/null || true)"
  if [[ -n "$host" ]] && curl -ksf "https://${host}/api/v1/version" >/dev/null 2>&1; then ok "https://${host}"; else err "unreachable"; fail=1; fi
  printf "  %-28s" "mirror (${MIRROR_ORG}/${MIRROR_REPO})"
  if [[ -n "$host" ]] && curl -ksf "https://${host}/api/v1/repos/${MIRROR_ORG}/${MIRROR_REPO}" >/dev/null 2>&1; then ok "mirrored"; else err "missing — run: ws git-refresh"; fail=1; fi
  printf "  %-28s" "workshop layer"
  local wsh
  wsh="$(oc get application workshop-config -n "$ARGO_NS" -o jsonpath='{.status.health.status}' 2>/dev/null || true)"
  if [[ "$wsh" == "Healthy" ]]; then ok "workshop-config Healthy"; else err "workshop-config ${wsh:-absent} — run bootstrap/install.sh"; fail=1; fi
  printf "  %-28s" "workshop IdP"
  if oc get oauth cluster -o jsonpath='{.spec.identityProviders[*].name}' 2>/dev/null | grep -qw workshop-users; then ok "workshop-users present"; else err "IdP missing — bootstrap adds it"; fail=1; fi
  printf "  %-28s" "user namespaces"
  if oc get ns user1-dev >/dev/null 2>&1; then ok "user1-dev exists"; else err "missing — workshop-config not synced"; fail=1; fi
  echo
  if (( fail == 0 )); then ok "environment looks good"; else err "issues found — fix hints above"; exit 1; fi
}

main() {
  local cmd="${1:-}"; shift || true
  # git-refresh self-parses its own flags (--restart-terminals/--user/--all/--exclude, where
  # --exclude takes a value); route its raw args straight through so the generic module parser
  # below never mis-bins that value as a module. "$@" is set -u-safe when empty (unlike an array).
  [[ "$cmd" == "git-refresh" ]] && { cmd_git_refresh "$@"; return; }
  local user="" module="" extra=()
  # collect --user anywhere; first bare arg = module
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --user) user="$2"; shift 2;;
      --all-users) user="--all-users"; shift;;
      -*) extra+=("$1"); shift;;
      *) [[ -z "$module" ]] && module="$1" || extra+=("$1"); shift;;
    esac
  done
  case "$cmd" in
    list)        cmd_list;;
    prep)        cmd_prep "$(user_arg "$user")" "$(module_arg "$module")" ${extra[@]:+"${extra[@]}"};;
    start)       cmd_start "$(user_arg "$user")" "$(module_arg "$module")";;
    verify)      cmd_verify "$(user_arg "$user")" "$(module_arg "$module")" ${extra[@]:+"${extra[@]}"};;
    smoke)       cmd_smoke "$(user_arg "$user")" "$(module_arg "$module")" ${extra[@]:+"${extra[@]}"};;
    reset)       cmd_reset "$(user_arg "$user")" "$(module_arg "$module")";;
    solve)       cmd_solve "$(user_arg "$user")" "$(module_arg "$module")";;
    doctor)      cmd_doctor;;
    ""|help|-h|--help) grep '^#' "$0" | sed 's/^# \{0,1\}//' | sed -n '2,12p';;
    *) die "unknown command '$cmd' — try: ws help";;
  esac
}
main "$@"
