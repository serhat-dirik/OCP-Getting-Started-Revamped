{{!
  Showroom cockpit header. Overrides the RHDP theme header so the top bar greets the
  attendee with "You are {user}" — page.attributes.user is injected at build time from the
  per-user userdata ConfigMap (gitops/workshop-config/templates/showroom.yaml). Pattern from
  rhpds hyperledger-on-openshift-demo showroom/site.yml.
}}
<header class="header">
  <nav class="navbar">
    <div class="navbar-brand">
      <a class="navbar-item" href="https://www.redhat.com" target="_blank" rel="noopener" style="margin-left: 5%;">
        <svg height="36" viewBox="0 0 192.3 146" xmlns="http://www.w3.org/2000/svg"><path d="m128 84c12.5 0 30.6-2.6 30.6-17.5a19.53 19.53 0 00-.3-3.4l-7.4-32.4c-1.7-7.1-3.2-10.4-15.7-16.6C125.5 9.1 104.4 1 98.1 1 92.2 1 90.5 8.5 83.6 8.5 76.9 8.5 72 2.9 65.7 2.9c-6 0-9.9 4.1-12.9 12.5 0 0-8.4 23.7-9.5 27.2a6.15 6.15 0 00-.2 1.9c-.1 9.2 36.2 39.4 84.9 39.5m32.5-11.4c1.7 8.2 1.7 9.1 1.7 10.1 0 14-15.7 21.8-36.4 21.8C79 104.5 38.1 77.1 38.1 59a18.35 18.35 0 011.5-7.3C22.8 52.5 1 55.5 1 74.7 1 106.2 75.6 145 134.6 145c45.3 0 56.7-20.5 56.7-36.7 0-12.7-11-27.1-30.8-35.7" fill="#e00"/><path d="m160.5 72.6c1.7 8.2 1.7 9.1 1.7 10.1 0 14-15.7 21.8-36.4 21.8C79 104.5 38.1 77.1 38.1 59a18.35 18.35 0 011.5-7.3l3.7-9.1a6.15 6.15 0 00-.2 1.9c0 9.2 36.3 39.4 84.9 39.4 12.5 0 30.6-2.6 30.6-17.5a19.53 19.53 0 00-.3-3.4z" fill="#191919"/></svg>
      </a>
      <a class="navbar-item site-title" target="__blank" style="color: #fff !important;" href="{{{or site.url (or siteRootUrl siteRootPath)}}}">{{site.title}}</a>
    </div>
    <div id="topbar-nav" class="navbar-menu">
      <div class="navbar-end">
        {{#if page.attributes.user}}
        <div class="navbar-item">You are <strong>&nbsp;{{page.attributes.user}}</strong></div>
        {{/if}}
      </div>
    </div>
  </nav>
</header>
