flowchart TB
  subgraph OBS["observe & steer (this module)"]
    MET[metrics + alerts]
    TRC[traces]
    HPA2[HPA autoscaling]
    PDB2[PDB resilience]
  end
  subgraph PLAT["the Parasol claims platform so far"]
    APP[claims service + db]
    DEL[pipelines + GitOps]
  end
  OBS --> APP
  OBS --> DEL
  classDef hi fill:#e00,stroke:#900,color:#fff;
  classDef plat fill:#f3f3f3,stroke:#888,color:#333;
  class MET,TRC,HPA2,PDB2 hi;
  class APP,DEL plat;
