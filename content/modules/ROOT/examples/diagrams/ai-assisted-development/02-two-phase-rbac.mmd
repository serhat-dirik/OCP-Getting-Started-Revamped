graph TD
  subgraph p1["Phase 1 — read-only (eyes)"]
    v["mcp-agent → ClusterRole 'view'<br/>(RoleBinding, namespaced)<br/>list/get pods, events, deployments, logs<br/><b>no secrets, no writes, one namespace</b>"]
  end
  subgraph p2["Phase 2 — scoped write (hands)"]
    e["+ a small 'deployer' Role<br/>patch/update deployments in THIS namespace only<br/><b>still no secrets, still one namespace</b>"]
  end
  diag["Agent DIAGNOSES the broken app"] --> p1
  p1 --> grant["You grant the scoped write<br/>(a human decision)"]
  grant --> p2
  p2 --> fix["Agent FIXES the one field"]
  p2 --> forbidden["Agent asked to touch another namespace<br/>→ <b>RBAC denies it (403)</b>"]
  classDef ro fill:#e8f0fe,stroke:#1967d2,color:#174ea6;
  classDef rw fill:#fef7e0,stroke:#b06000,color:#7a4100;
  classDef deny fill:#fce8e6,stroke:#c5221f,color:#a50e0e;
  class v ro; class e rw; class forbidden deny;
