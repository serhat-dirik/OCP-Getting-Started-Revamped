graph LR
  cli["AI assistant / CLI<br/>(the MCP client)<br/><b>holds NO kubeconfig</b>"]
  subgraph ns["your {user}-dev namespace"]
    mcp["MCP server<br/>runs as ServiceAccount<br/><b>mcp-agent</b>"]
  end
  api["Kubernetes API server"]
  rbac{"RBAC check:<br/>what may<br/>mcp-agent do?"}
  cli -->|"tool call (HTTP/SSE)"| mcp
  mcp -->|"acts as mcp-agent's<br/>projected token"| rbac
  rbac -->|"allowed → do it"| api
  rbac -.->|"denied → 403"| mcp
  cli -->|"chat + tool schema"| model["your cluster's served model<br/>(MaaS, OpenAI-compatible)"]
  classDef client fill:#e8eaf6,stroke:#3949ab,color:#1a237e;
  classDef server fill:#fef7e0,stroke:#b06000,color:#7a4100;
  classDef gate fill:#fce8e6,stroke:#c5221f,color:#a50e0e;
  classDef ext fill:#e6f4ea,stroke:#137333,color:#0d652d;
  class cli client; class mcp server; class rbac gate; class api,model ext;
