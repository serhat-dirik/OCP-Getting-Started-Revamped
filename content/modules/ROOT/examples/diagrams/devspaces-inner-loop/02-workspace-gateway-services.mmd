graph TB
  subgraph browser["Your browser"]
    ide["che-code IDE<br/>(VS Code in a tab)"]
  end
  subgraph cluster["OpenShift cluster"]
    subgraph wsns["Workspace project (your-name-devspaces)"]
      gw["che-gateway<br/>(HTTPS, per-user auth)"]
      tools["tools container (UDI)<br/>Quarkus dev mode :8080 · debug :5005"]
      gw --- tools
    end
    subgraph devns["App project (your-name-dev)"]
      db[("claims-db<br/>PostgreSQL :5432")]
    end
    tools -->|"cross-namespace DNS<br/>claims-db.your-name-dev.svc:5432"| db
  end
  ide -->|HTTPS| gw
  classDef hi fill:#e00,stroke:#900,color:#fff;
  classDef plat fill:#f3f3f3,stroke:#888,color:#333;
  class tools,gw hi;
  class db plat;
