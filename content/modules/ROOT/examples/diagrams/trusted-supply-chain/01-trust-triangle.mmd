flowchart LR
  SRC[(Source repo\nparasol-claims)] --> BUILD
  subgraph PIPE["Supply-chain pipeline (in your -cicd namespace)"]
    direction TB
    SBOMT[SBOM report\nCycloneDX] --> BUILD[build-image\nbuildah]
    BUILD --> SCAN{scan gate\nRHACS}
  end
  BUILD -. Tekton Chains signs .-> SIG[[signature + SLSA provenance\nstored beside the image]]
  SCAN -->|clean| REG[(image + .sig + .att\nin the registry)]
  SCAN -->|CVE found| STOP[/build fails —\nimage never ships/]
  SIG --> REG
  REG --> ADM{ImagePolicy\nadmission}
  ADM -->|signed| RUN([pod runs])
  ADM -->|unsigned| DENY[/pull refused/]
  classDef g fill:#e6f4ea,stroke:#137333,color:#0d652d;
  classDef r fill:#fce8e6,stroke:#c5221f,color:#a50e0e;
