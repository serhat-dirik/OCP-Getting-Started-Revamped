graph TB
  subgraph cluster["OpenShift cluster"]
    subgraph proj["Your project (your-name-dev)"]
      DEP["Deployment: parasol-web<br/>(desired: N replicas)"]:::hi
      POD1["Pod"]:::hi
      POD2["Pod"]:::hi
      POD3["Pod"]:::hi
      SVC["Service :8080"]:::hi
      DEP --> POD1 & POD2 & POD3
      SVC -.-> POD1 & POD2 & POD3
    end
    RT["Route<br/>(per-user URL)"]:::hi
    RT --> SVC
    SEC["Security defaults<br/>non-root · random UID · restricted"]:::plat
    CON["Web console · Lightspeed"]:::plat
    SEC -.applied to.-> POD1
  end
  USER([Adjuster]) -->|HTTPS| RT
  classDef hi fill:#e00,stroke:#900,color:#fff;
  classDef plat fill:#f3f3f3,stroke:#888,color:#333;
