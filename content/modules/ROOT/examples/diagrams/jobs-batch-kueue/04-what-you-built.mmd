graph LR
  job["Job / CronJob<br/>completions · parallelism<br/>Indexed · schedule"] -->|"label: queue-name"| lq["LocalQueue<br/>user-queue"]
  lq --> cq["ClusterQueue cq-user<br/>quota · priority · preemption"]
  cq --> adm["Admitted (2)"]
  cq --> pend["Pending (3)"]
  cq --> pre["Preempted → Requeued"]
  ai["AI batch inference<br/>(same label, same object)"] -->|"queue-name"| lq
  classDef done fill:#e6f4ea,stroke:#137333,color:#0d652d;
  classDef q fill:#e00,stroke:#900,color:#fff;
  classDef wait fill:#fef7e0,stroke:#b06000,color:#7a4100;
  class job,ai done;
  class lq,cq q;
  class adm done;
  class pend,pre wait;
