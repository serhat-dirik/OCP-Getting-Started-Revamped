graph LR
  subgraph req["Request-driven (so far)"]
    r["Deployment + Service<br/>caller waits · low latency"]
  end
  subgraph evt["Event-driven"]
    e["handler per message/event<br/>reacts in seconds"]
  end
  subgraph bat["Batch (this module)"]
