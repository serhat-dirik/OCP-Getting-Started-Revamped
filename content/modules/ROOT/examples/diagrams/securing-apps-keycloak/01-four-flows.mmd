flowchart TB
  subgraph HUMAN["a human is present"]
    WEB["<b>Auth-code + PKCE</b><br/>browser logs in at Keycloak,<br/>app never sees the password<br/>— the web frontend"]
    BEARER["<b>Bearer token</b><br/>caller presents a token,<br/>API validates + checks role<br/>— the claims API"]
  end
  subgraph MACHINE["no human — service to service"]
    CC["<b>Client credentials</b><br/>a service authenticates<br/>as ITSELF<br/>— the batch job"]
    TE["<b>Token exchange (RFC 8693)</b><br/>one service re-audiences a<br/>user's token to call another<br/>ON THE USER'S BEHALF"]
  end
  WEB -->|"user's token<br/>is then sent to"| BEARER
  BEARER -->|"re-audienced by<br/>exchange into"| TE
  classDef human fill:#e6f4ea,stroke:#137333,color:#0d652d;
  classDef machine fill:#e8f0fe,stroke:#1a73e8,color:#174ea6;
  class WEB,BEARER human;
  class CC,TE machine;
