flowchart TB
  subgraph SEC["identity & access (this module)"]
    LOGIN[web login<br/>auth-code + PKCE]
    API[bearer-protected API<br/>+ role checks]
    M2M[machine identity<br/>client credentials]
    EXCH[token exchange<br/>service to service]
  end
  subgraph PLAT["the Parasol claims platform so far"]
    APP[claims + web + db]
    DEL[pipelines + GitOps + observability]
  end
  KC[Red Hat build of Keycloak<br/>per-user realm]
  KC --> SEC
  SEC --> APP
  SEC --> DEL
  classDef hi fill:#e00,stroke:#900,color:#fff;
  classDef plat fill:#f3f3f3,stroke:#888,color:#333;
  classDef kc fill:#fef7e0,stroke:#f9ab00,color:#b06000;
  class LOGIN,API,M2M,EXCH hi;
  class APP,DEL plat;
  class KC kc;
