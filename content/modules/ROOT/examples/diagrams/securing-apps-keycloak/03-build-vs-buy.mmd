flowchart LR
  subgraph BUILD["build it yourself"]
    B1["password hashing<br/>+ reset flows"]
    B2["session store<br/>+ CSRF"]
    B3["MFA, lockout,<br/>audit, federation"]
    B4["...and keep it<br/>patched forever"]
  end
  subgraph BUY["use the platform"]
    K["Red Hat build<br/>of Keycloak<br/>— included with<br/>OpenShift"]
  end
  BUILD -.->|"months of work,<br/>your bug surface"| RISK["every one is a<br/>breach waiting"]
  BUY -->|"configure, don't code"| DONE["SSO, MFA, federation,<br/>audit — day one"]
  classDef bad fill:#fce8e6,stroke:#c5221f,color:#a50e0e;
  classDef good fill:#e6f4ea,stroke:#137333,color:#0d652d;
  class B1,B2,B3,B4,RISK bad;
  class K,DONE good;
