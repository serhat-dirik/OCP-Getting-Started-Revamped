flowchart TD
  REALM["<b>Realm</b> — an isolated world of identity<br/>(this workshop: one realm per attendee)"]
  REALM --> CLIENTS["<b>Clients</b> — the apps that use the realm"]
  REALM --> ROLES["<b>Roles</b> — named permissions"]
  REALM --> USERS["<b>Users</b> — the people who log in"]
  CLIENTS --> C1["parasol-web<br/>(public, browser login)"]
  CLIENTS --> C2["parasol-claims<br/>(confidential API)"]
  CLIENTS --> C3["parasol-fraud<br/>(bearer-only API)"]
  CLIENTS --> C4["parasol-batch<br/>(machine identity)"]
  ROLES --> R1["claims-adjuster"]
  USERS --> U1["adjuster<br/>(has claims-adjuster)"]
  USERS --> U2["viewer<br/>(no roles)"]
  classDef realm fill:#fef7e0,stroke:#f9ab00,color:#b06000;
  classDef kind fill:#f3f3f3,stroke:#888,color:#333;
  classDef leaf fill:#e8f0fe,stroke:#1a73e8,color:#174ea6;
  class REALM realm;
  class CLIENTS,ROLES,USERS kind;
  class C1,C2,C3,C4,R1,U1,U2 leaf;
