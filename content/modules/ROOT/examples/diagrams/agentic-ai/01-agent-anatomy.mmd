graph TD
  subgraph agent["parasol-agent (a Quarkus service)"]
    instr["Instructions<br/>(system prompt:<br/>'use your tools, never guess,<br/>cite the policy id')"]
    model["Model<br/>(reasons + decides<br/>which tool to call)"]
    mem["Memory<br/>(per-request:<br/>holds the tool round-trip)"]
    tools["Tools<br/>(the MCP servers:<br/>claims-db · policy-docs)"]
  end
  q["Staff question"] --> model
  instr --> model
  model <--> mem
  model -->|"decides to call"| tools
  tools -->|"grounded facts"| model
  model --> a["Grounded answer<br/>+ which tools it called<br/>+ tokens used"]
  classDef svc fill:#e8eaf6,stroke:#3949ab,color:#1a237e;
  classDef io fill:#e6f4ea,stroke:#137333,color:#0d652d;
  classDef tool fill:#fef7e0,stroke:#b06000,color:#7a4100;
  class instr,model,mem svc; class q,a io; class tools tool;
