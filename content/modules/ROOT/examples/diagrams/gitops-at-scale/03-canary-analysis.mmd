flowchart LR
  NEW[new version pushed<br/>via Git] --> C25[canary 25%]
  C25 --> P[pause]
  P --> C50[canary 50%]
  C50 --> AN{analysis gate}
  AN -->|pass| FULL[100% - promoted]
  AN -->|fail| RB[abort and<br/>roll back to stable]
  classDef g fill:#e6f4ea,stroke:#137333,color:#0d652d;
  classDef a fill:#fef5e7,stroke:#b7791f,color:#744210;
  classDef r fill:#fde8e8,stroke:#c0392b,color:#7b241c;
  class NEW,C25,C50,FULL g;
  class P,AN a;
  class RB r;
