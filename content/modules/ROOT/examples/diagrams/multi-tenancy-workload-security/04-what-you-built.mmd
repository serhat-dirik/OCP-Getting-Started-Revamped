graph TB
  subgraph tenant["Tenant sandbox — dev / stage / prod"]
    sa1["payments-ci<br/>edit@dev · view@prod"]
    sa2["payments-ops<br/>custom deployer Role<br/>(no secrets)"]
    wl["root-demander<br/>non-root UID<br/>restricted-v2"]
    q["ResourceQuota + LimitRange<br/>(platform-owned)"]
  end
  subgraph platform["Platform team — cluster scope"]
    obs["platform-observer<br/>(read-only facts)"]
    sp["self-provisioning<br/>+ project template"]
    idp["OAuth IdPs<br/>htpasswd + Keycloak"]
  end
  platform -->|"provisions + governs"| tenant
  classDef t fill:#e6f4ea,stroke:#137333,color:#0d652d;
  classDef p fill:#e8eaf6,stroke:#3949ab,color:#1a237e;
  class sa1,sa2,wl,q t;
  class obs,sp,idp p;
