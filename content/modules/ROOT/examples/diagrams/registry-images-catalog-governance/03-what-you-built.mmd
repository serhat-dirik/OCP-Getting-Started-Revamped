graph TB
  subgraph you["Yours (namespaced)"]
    is["parasol-claims<br/>1.0 → prod (same digest)"]
    ext["ext-ubi<br/>scheduled import"]
    tmpl["namespaced Template<br/>your catalog entry"]
    sec["pull secret<br/>→ SA / pod"]
  end
  subgraph platform["Platform (cluster-wide — you read)"]
    allow["allowedRegistriesForImport<br/>IDMS / ITMS"]
    prune["nightly pruner<br/>keep 3 revisions"]
    samples["samples operator<br/>ConsoleSample · catalog sources"]
  end
  reg[("Internal registry<br/>svc:5000")]
  is --> reg
  ext --> reg
  allow -->|"governs"| reg
  prune -->|"reclaims"| reg
  samples -->|"feeds"| dcat["Developer Catalog"]
  tmpl -->|"feeds (your ns only)"| dcat
  classDef ok fill:#e6f4ea,stroke:#137333,color:#0d652d;
  classDef gov fill:#fef7e0,stroke:#b06000,color:#7a4100;
  classDef reg fill:#e8eaf6,stroke:#3949ab,color:#1a237e;
  class is,ext,tmpl,sec ok;
  class allow,prune,samples gov;
  class reg,dcat reg;
