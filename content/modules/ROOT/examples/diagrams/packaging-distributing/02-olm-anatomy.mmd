graph TB
  cat["CatalogSource<br/>(a catalog index image)"] --> pm["PackageManifest<br/>(the operator's channels)"]
  pm --> sub["Subscription<br/>you pick a channel"]
  sub --> ip["InstallPlan<br/>Automatic or Manual approval"]
  ip --> csv["ClusterServiceVersion (CSV)<br/>owned CRDs + controller Deployment + RBAC"]
  csv --> pod["Operator Pod<br/>reconciles your custom resources"]
  classDef cat fill:#e8eaf6,stroke:#3949ab,color:#1a237e;
  classDef pick fill:#fef7e0,stroke:#b06000,color:#7a4100;
  classDef run fill:#e6f4ea,stroke:#137333,color:#0d652d;
  class cat,pm cat; class sub,ip pick; class csv,pod run;
