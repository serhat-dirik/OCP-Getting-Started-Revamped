graph TB
  q0["Should anything outside the cluster reach it?"]
  q0 -->|no| clusterip["ClusterIP (default)<br/>in-cluster only — most workloads live here"]
  q0 -->|yes| q1{"What kind of traffic?"}
  q1 -->|"HTTP(S) / TLS-SNI"| route["Route → the workhorse<br/>external, wildcard DNS, edge TLS<br/>(Gateway API = the strategic direction)"]
  q1 -->|"raw TCP / UDP / passthrough"| l4["needs a LoadBalancer or the mesh<br/>(L4 — a later module)"]
  nodeport["NodePort<br/>a port on every node — learn it once,<br/>reach for it almost never"]
  lb["LoadBalancer<br/>needs a provider (cloud LB / MetalLB);<br/>without one it stays &lt;pending&gt;"]
  q1 -.->|"low-level / debugging"| nodeport
  l4 -.-> lb
  classDef def fill:#e6f4ea,stroke:#137333,color:#0d652d;
  classDef warn fill:#fef7e0,stroke:#b06000,color:#7a4100;
  classDef bad fill:#fce8e6,stroke:#c5221f,color:#a50e0e;
  class clusterip,route def;
  class nodeport,lb warn;
  class l4 bad;
