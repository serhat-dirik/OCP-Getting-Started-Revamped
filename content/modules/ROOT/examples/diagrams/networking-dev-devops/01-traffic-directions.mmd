graph TB
  subgraph outside["Outside the cluster"]
    user["Browser / partner system"]
  end
  subgraph ns["Namespace: your app"]
    web["web tier"]
    api["api tier"]
    db[("database")]
  end
  user -->|"NORTH-SOUTH<br/>(what you expose:<br/>Route / Gateway API)"| web
  web -->|"east-west"| api
  api -->|"east-west"| db
  note["EAST-WEST<br/>(who may talk to whom:<br/>NetworkPolicy / UDN)"]
  note -.-> web
  classDef out fill:#e8eaf6,stroke:#3949ab,color:#1a237e;
  classDef app fill:#e6f4ea,stroke:#137333,color:#0d652d;
  classDef lbl fill:#fef7e0,stroke:#b06000,color:#7a4100;
  class user out;
  class web,api,db app;
  class note lbl;
