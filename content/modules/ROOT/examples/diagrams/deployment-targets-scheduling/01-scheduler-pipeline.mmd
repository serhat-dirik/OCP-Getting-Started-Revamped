graph LR
  pod["Pending pod<br/>(requests: cpu/mem,<br/>tolerations, selectors)"]
  subgraph sched["kube-scheduler"]
    filter["1 · FILTER<br/>which nodes CAN run it?<br/>enough free requests · taints tolerated ·<br/>nodeSelector/affinity match"]
    score["2 · SCORE<br/>which survivor is BEST?<br/>most room · best spread ·<br/>anti-affinity honoured"]
  end
  bind["BIND to the winning node"]
  fail["no node survives →<br/>Pending + FailedScheduling event"]
  pod --> filter --> score --> bind
  filter -. "0 survive" .-> fail
  classDef p fill:#e8eaf6,stroke:#3949ab,color:#1a237e;
  classDef s fill:#e6f4ea,stroke:#137333,color:#0d652d;
  classDef b fill:#e6f4ea,stroke:#137333,color:#0d652d;
  classDef f fill:#fce8e6,stroke:#c5221f,color:#a50e0e;
  class pod p; class filter,score s; class bind b; class fail f;
