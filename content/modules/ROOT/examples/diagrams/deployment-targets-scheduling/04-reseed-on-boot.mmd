graph LR
  req["client files a claim"]
  subgraph roll["RollingUpdate · maxUnavailable 0 keeps pods Ready"]
    old["OLD pod<br/>still serving"]
    new["NEW pod BOOTING<br/>Hibernate drop-and-create"]
  end
  db[("shared claims-db<br/>one PostgreSQL")]
  req -->|"POST /api/claims"| old
  old -->|"INSERT (committed)"| db
  new -->|"DROP + reseed<br/>the schema on boot"| db
  db -.->|"the new claim is discarded —<br/>no error, just gone"| req
  classDef ok fill:#e6f4ea,stroke:#137333,color:#0d652d;
  classDef bad fill:#fce8e6,stroke:#c5221f,color:#a50e0e;
  classDef data fill:#e8eaf6,stroke:#3949ab,color:#1a237e;
  class old ok; class new bad; class db,req data;
