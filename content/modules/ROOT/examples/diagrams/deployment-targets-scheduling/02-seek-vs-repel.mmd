graph TB
  subgraph seek["AFFINITY — the POD seeks (attract)"]
    p1["pod: nodeSelector / nodeAffinity<br/>'put me on a node like this'"]
    n1["node with matching label"]
    p1 -->|"pulls toward"| n1
  end
  subgraph repel["TAINT — the NODE repels"]
    n2["node: taint<br/>'keep pods off me'"]
    p2["pod without toleration"]
    p3["pod WITH toleration"]
    n2 -.->|"pushes away"| p2
    p3 -->|"tolerated → permitted<br/>(but not attracted)"| n2
  end
  classDef a fill:#e6f4ea,stroke:#137333,color:#0d652d;
  classDef r fill:#fef7e0,stroke:#b06000,color:#7a4100;
  class p1,n1 a; class n2,p2,p3 r;
