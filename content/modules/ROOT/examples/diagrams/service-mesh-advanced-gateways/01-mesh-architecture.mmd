graph TB
  subgraph cp["Control plane — istio-system"]
    istiod["istiod<br/>config + identity (mTLS certs)<br/>OSSM Sail operator"]
    kiali["Kiali console<br/>graph · health · mTLS badges"]
  end
  subgraph mesh["Data plane — your {user}-mesh namespace"]
    subgraph webpod["web pod"]
      web["parasol-web"] --- wsc(("proxy"))
    end
    subgraph claimspod["claims pod"]
      claims["parasol-claims"] --- csc(("proxy"))
    end
    subgraph fraudpod["fraud pod"]
      fraud["parasol-fraud"] --- fsc(("proxy"))
    end
  end
  client["demo-client<br/>(un-meshed · no proxy)"]
  istiod -.->|"pushes config + certs"| wsc
  istiod -.->|"pushes config + certs"| csc
  istiod -.->|"pushes config + certs"| fsc
  wsc ==>|"mTLS"| csc
  csc ==>|"mTLS"| fsc
  client -.->|"plaintext<br/>(blocked under STRICT)"| wsc
  kiali -.->|"reads telemetry"| csc
  classDef cp fill:#e8eaf6,stroke:#3949ab,color:#1a237e;
  classDef app fill:#e6f4ea,stroke:#137333,color:#0d652d;
  classDef proxy fill:#fef7e0,stroke:#b06000,color:#7a4100;
  classDef ext fill:#fce8e6,stroke:#c5221f,color:#a50e0e;
  class istiod,kiali cp; class web,claims,fraud app; class wsc,csc,fsc proxy; class client ext;
