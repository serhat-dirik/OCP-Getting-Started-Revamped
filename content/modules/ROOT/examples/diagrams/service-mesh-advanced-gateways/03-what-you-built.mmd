graph TB
  subgraph ns["{user}-mesh — after the lab"]
    web["parasol-web<br/>(meshed)"]
    claims["parasol-claims<br/>(meshed · sa/parasol-claims)"]
    fraud["parasol-fraud v1 + v2<br/>(meshed)"]
    db[("claims-db<br/>un-meshed")]
  end
  subgraph policy["Mesh policy you applied"]
    vs["VirtualService<br/>90/10 + header route"]
    dr["DestinationRule<br/>subsets + circuit breaker"]
    ap["AuthorizationPolicy<br/>only claims -> fraud"]
    gw["Istio Gateway<br/>raw-TCP + rate limit"]
  end
  web ==>|"mTLS"| claims
  claims ==>|"mTLS · 90/10 · authz"| fraud
  claims --> db
  vs -.->|"routes"| fraud
  dr -.->|"resilience"| fraud
  ap -.->|"guards"| fraud
  gw -.->|"ingress"| ns
  classDef app fill:#e6f4ea,stroke:#137333,color:#0d652d;
  classDef pol fill:#fef7e0,stroke:#b06000,color:#7a4100;
  classDef db fill:#e8eaf6,stroke:#3949ab,color:#1a237e;
  class web,claims,fraud app; class vs,dr,ap,gw pol; class db db;
