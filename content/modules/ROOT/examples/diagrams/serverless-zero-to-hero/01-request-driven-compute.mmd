graph LR
  client(["client / browser"])
  subgraph ksvc["Knative Service: parasol-claims"]
    route["Route<br/>(auto edge Route, Kourier)<br/>ksvc.status.url"]
    config["Configuration<br/>(latest desired version)"]
    subgraph revs["Revisions (immutable)"]
      v1["Revision v1<br/>#stable · 80%"]
      v2["Revision v2<br/>#candidate · 20%"]
    end
    kpa{{"KPA<br/>scale 0..N<br/>on concurrency"}}
  end
  subgraph evt["Eventing taste (source -> broker -> trigger)"]
    ping["PingSource"] --> broker[("Broker<br/>in-memory")]
    broker --> trig["Trigger"]
  end
  client -->|"HTTPS"| route
  route -->|"80%"| v1
  route -->|"20%"| v2
  config -.->|"mints"| v2
  kpa -.->|"0..N pods"| revs
  trig -->|"delivers event,<br/>wakes the ksvc"| route
  classDef svc fill:#e6f4ea,stroke:#137333,color:#0d652d;
  classDef ctl fill:#e8eaf6,stroke:#3949ab,color:#1a237e;
  classDef evt fill:#fef7e0,stroke:#b06000,color:#7a4100;
  class v1,v2 svc; class route,config,kpa ctl; class ping,broker,trig evt;
