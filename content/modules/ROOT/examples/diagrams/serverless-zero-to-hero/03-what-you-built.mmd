graph TB
  subgraph ns["{user}-dev — after the lab"]
    subgraph ksvc["parasol-claims (ksvc)"]
      route["Route<br/>(auto edge, Kourier)<br/>80% stable / 20% candidate"]
      v1["Revision v1<br/>#stable"]
      v2["Revision v2<br/>#candidate · CC=2 · max-scale 3"]
    end
    ping["PingSource<br/>claim-ticker"] --> broker[("Broker<br/>default (in-memory)")]
    broker --> trig["Trigger<br/>claims-processor"]
  end
  client(["client"]) -->|"HTTPS"| route
  route -->|"80%"| v1
  route -->|"20%"| v2
  kpa{{"KPA · scale 0..3<br/>on concurrency"}} -.-> v1
  kpa -.-> v2
  trig -->|"wakes on event -> 404 (Eventing Deep-Dive)"| route
  classDef svc fill:#e6f4ea,stroke:#137333,color:#0d652d;
  classDef ctl fill:#e8eaf6,stroke:#3949ab,color:#1a237e;
  classDef evt fill:#fef7e0,stroke:#b06000,color:#7a4100;
  class v1,v2 svc; class route,kpa ctl; class ping,broker,trig evt;
