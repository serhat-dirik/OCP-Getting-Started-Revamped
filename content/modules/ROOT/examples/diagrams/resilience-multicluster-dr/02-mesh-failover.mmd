graph LR
  client["external client<br/>(stable endpoint,<br/>never reconfigured)"]
  subgraph mesh["OpenShift Service Mesh"]
    gw["ingress Gateway<br/>(pinned to site A's locality)"]
    subgraph a["Site A — PRIMARY"]
      sa["claims (SITE=A)<br/>3 replicas + PDB + HPA"]
    end
    subgraph b["Site B — SECONDARY"]
      sb["claims (SITE=B)<br/>3 replicas + PDB + HPA"]
    end
  end
  client -->|"HTTP"| gw
  gw ==>|"normal: locality prefers A"| sa
  gw -.->|"on A failure: outlier ejects A,<br/>retries flip to B"| sb
  classDef c fill:#e8eaf6,stroke:#3949ab,color:#1a237e;
  classDef g fill:#ede7f6,stroke:#5e35b1,color:#311b92;
  classDef pa fill:#e6f4ea,stroke:#137333,color:#0d652d;
  classDef pb fill:#fef7e0,stroke:#b06000,color:#7a4100;
  class client c; class gw g; class sa pa; class sb pb;
