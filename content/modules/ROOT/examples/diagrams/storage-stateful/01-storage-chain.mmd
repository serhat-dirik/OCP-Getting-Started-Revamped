graph TB
  app["Pod<br/>your database"] -->|mounts| pvc["PersistentVolumeClaim<br/>what you ask for (your namespace)"]
  pvc -->|bound to| pv["PersistentVolume<br/>what the platform gives you (cluster-scoped)"]
  pv -->|created from| sc["StorageClass<br/>the recipe the platform follows"]
  sc -->|carves real disk from| backend[("Cluster storage backend")]
  classDef ask fill:#e00,stroke:#900,color:#fff;
  classDef plat fill:#f3f3f3,stroke:#888,color:#333;
  class pvc ask;
  class pv,sc,backend plat;
