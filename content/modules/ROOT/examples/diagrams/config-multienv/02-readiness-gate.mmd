graph TB
  route["Route / Service"]
  subgraph ready["Pod — readiness PASSING"]
    r1["in the Service endpoints<br/>receives traffic"]
  end
  subgraph notready["Pod — readiness FAILING"]
    r2["removed from endpoints<br/>traffic held (Route → 503)"]
  end
  route -->|"traffic"| r1
  route -.->|"no endpoint"| r2
  classDef ok fill:#e6f4ea,stroke:#137333,color:#0d652d;
  classDef bad fill:#fce8e6,stroke:#c5221f,color:#a50e0e;
  class r1 ok;
  class r2 bad;
