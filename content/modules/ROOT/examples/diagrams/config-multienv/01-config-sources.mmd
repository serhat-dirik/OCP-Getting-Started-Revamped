graph LR
  subgraph img["The image (built once, never changes)"]
    app["parasol-claims<br/>reads config at startup"]
  end
  env["Env vars<br/>(inline)"] --> app
  cm["ConfigMap<br/>(non-secret config)"] --> app
  sec["Secret<br/>(credentials)"] --> app
  file["Mounted file<br/>(config as a volume)"] --> app
  classDef art fill:#e00,stroke:#900,color:#fff;
  classDef cfg fill:#f3f3f3,stroke:#888,color:#333;
  class app art;
  class env,cm,sec,file cfg;
