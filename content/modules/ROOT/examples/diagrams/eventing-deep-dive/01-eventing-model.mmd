graph LR
  src["PingSource<br/>claim-ticker<br/>(seeded source)"]
  subgraph broker_box["Broker: default (in-memory)"]
    broker[("Broker<br/>ingress + channel")]
  end
  t1{"Trigger<br/>claims-events<br/>(no filter)"}
  t2{"Trigger<br/>claims-fraud-review<br/>filter: type=claim.submitted"}
  t3{"Trigger<br/>claims-audit<br/>filter: claimpriority=high"}
  consumer["claims-consumer (ksvc)<br/>returns 200/204<br/>DISPLAYS the event<br/>scales 0..N on delivery"]
  dlq["claims-dlq (ksvc)<br/>dead-letter sink"]
  producer(["you: POST a CloudEvent"])
  src -->|"every 5 min"| broker
  producer -->|"HTTP 202"| broker
  broker --> t1 --> consumer
  broker --> t2 -->|"on repeated failure"| dlq
  t2 --> consumer
  broker --> t3 --> consumer
  classDef src fill:#fef7e0,stroke:#b06000,color:#7a4100;
  classDef hub fill:#e8eaf6,stroke:#3949ab,color:#1a237e;
  classDef trig fill:#e6f4ea,stroke:#137333,color:#0d652d;
  classDef sink fill:#e3f2fd,stroke:#1565c0,color:#0d47a1;
  class src,producer src; class broker hub; class t1,t2,t3 trig; class consumer,dlq sink;
