graph TB
  subgraph ns["{user}-dev — after the lab"]
    src["PingSource<br/>claim-ticker (seeded)"]
    broker[("Broker: default<br/>in-memory · synchronous")]
    t1{"claims-events<br/>(catch-all)"}
    t2{"claims-fraud-review<br/>filter type · retry 3 + DLQ"}
    t3{"claims-audit<br/>filter claimpriority=high"}
    consumer["claims-consumer (ksvc)<br/>200/204 · displays envelope<br/>scales 0..N on event"]
    dlq["claims-dlq (ksvc)<br/>dead-letter sink<br/>knativeerrorcode / dest"]
  end
  you(["you: POST a CloudEvent"]) -->|"202"| broker
  src -->|"every 5 min"| broker
  broker --> t1 --> consumer
  broker --> t2 --> consumer
  t2 -.->|"on exhausted retries"| dlq
  broker --> t3 --> consumer
  classDef src fill:#fef7e0,stroke:#b06000,color:#7a4100;
  classDef hub fill:#e8eaf6,stroke:#3949ab,color:#1a237e;
  classDef trig fill:#e6f4ea,stroke:#137333,color:#0d652d;
  classDef sink fill:#e3f2fd,stroke:#1565c0,color:#0d47a1;
  class src,you src; class broker hub; class t1,t2,t3 trig; class consumer,dlq sink;
