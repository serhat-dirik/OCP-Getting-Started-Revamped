flowchart LR
  subgraph PUSH["Push delivery (CI pushes in)"]
    direction LR
    CI[CI / pipeline<br/>holds cluster creds] -->|oc apply / rollout| NS1[(namespace)]
  end
  subgraph PULL["Pull delivery (GitOps — cluster pulls in)"]
    direction LR
    GIT[(Git repo<br/>desired state)] --> CTRL[Argo CD controller<br/>inside the cluster]
    CTRL -->|reconciles| NS2[(namespace)]
    NS2 -. observes live state .-> CTRL
  end
  classDef p fill:#e6f0ff,stroke:#2b6cb0,color:#1a365d;
  classDef g fill:#e6f4ea,stroke:#137333,color:#0d652d;
  class CI,NS1 p;
  class GIT,CTRL,NS2 g;
