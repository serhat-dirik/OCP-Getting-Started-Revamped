flowchart LR
  GIT[(Git: overlays/dev<br/>desired state)] --> APP[Application CR]
  APP --> RECON{{reconcile:<br/>diff desired vs live}}
  LIVE[(namespace<br/>live state)] --> RECON
  RECON -->|match| SYNCED[Synced + Healthy]
  RECON -->|differ| OOS[OutOfSync]
  OOS -->|Sync| LIVE
  classDef g fill:#e6f4ea,stroke:#137333,color:#0d652d;
  classDef a fill:#fef5e7,stroke:#b7791f,color:#744210;
  class GIT,LIVE,SYNCED g;
  class APP,RECON a;
  class OOS a;
